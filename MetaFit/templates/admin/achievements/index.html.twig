{% extends 'base.html.twig' %}

{% block title %}Logros - MetaFit AI{% endblock %}

{% block body %}
<div class="max-w-full mx-auto px-4 sm:px-6 pt-6 md:pt-8">

    {# HEADER #}
    <div class="mb-8 flex items-start justify-between flex-wrap gap-4">
        <div>
            <div class="flex items-center gap-4 mb-4">
                <div class="h-1 w-12 bg-red-500"></div>
                <span class="text-red-500 font-bold tracking-[0.3em] uppercase text-sm">Sistema Admin</span>
            </div>
            <h1 class="text-5xl font-black italic uppercase tracking-tighter mb-2">
                Gestión de <span class="text-red-500">Logros</span>
            </h1>
            <p class="text-gray-400 text-lg font-light">{{ achievements|length }} logros en la plataforma</p>
        </div>
        <a href="{{ path('admin_achievements_new') }}" class="inline-flex items-center gap-2 bg-red-500 hover:bg-red-600 text-white px-6 py-3 rounded-xl font-bold text-sm uppercase transition-all">
            <span class="material-symbols-outlined">add</span>
            Nuevo Logro
        </a>
    </div>

    {# FLASH MESSAGES #}
    {% for message in app.flashes('success') %}
        <div class="mb-4 p-4 bg-green-900/30 border border-green-500/30 rounded-xl text-green-400 text-sm font-bold">
            {{ message }}
        </div>
    {% endfor %}

    {# TABLA #}
    <div class="bg-[#0d1117] border border-slate-800 rounded-2xl overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-slate-800 text-slate-500 text-[10px] font-bold uppercase tracking-widest">
                        <th class="px-6 py-4 text-left">Orden</th>
                        <th class="px-6 py-4 text-left">Nombre</th>
                        <th class="px-6 py-4 text-left">Tipo</th>
                        <th class="px-6 py-4 text-left">Identificador</th>
                        <th class="px-6 py-4 text-center">XP</th>
                        <th class="px-6 py-4 text-center">Desbloqueado por</th>
                        <th class="px-6 py-4 text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800/50">
                    {% for achievement in achievements %}
                        <tr class="hover:bg-slate-900/30 transition-all">
                            <td class="px-6 py-4 text-slate-500 font-mono text-xs">{{ achievement.sortOrder }}</td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    {% if achievement.urlIcon %}
                                        <span class="material-symbols-outlined text-red-500 text-xl">{{ achievement.urlIcon }}</span>
                                    {% else %}
                                        <span class="material-symbols-outlined text-slate-600 text-xl">emoji_events</span>
                                    {% endif %}
                                    <div>
                                        <p class="font-bold text-white">{{ achievement.name }}</p>
                                        {% if achievement.description %}
                                            <p class="text-slate-500 text-xs mt-0.5 max-w-xs truncate">{{ achievement.description }}</p>
                                        {% endif %}
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="px-2 py-1 bg-slate-800 rounded-lg text-xs font-bold text-slate-300">{{ achievement.type }}</span>
                            </td>
                            <td class="px-6 py-4 font-mono text-xs text-slate-400">{{ achievement.judgment }}</td>
                            <td class="px-6 py-4 text-center">
                                <span class="text-red-500 font-black">+{{ achievement.otorgatedXp }}</span>
                            </td>
                            <td class="px-6 py-4 text-center">
                                <span class="text-slate-300 font-bold">{{ unlockedCounts[achievement.id] ?? 0 }}</span>
                                <span class="text-slate-500 text-xs ml-1">usuarios</span>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center justify-center gap-2">
                                    <a href="{{ path('admin_achievements_edit', {id: achievement.id}) }}"
                                       class="p-2 rounded-lg bg-slate-800 hover:bg-slate-700 text-slate-400 hover:text-white transition-all"
                                       title="Editar">
                                        <span class="material-symbols-outlined text-base">edit</span>
                                    </a>
                                    <form method="post" action="{{ path('admin_achievements_delete', {id: achievement.id}) }}"
                                          onsubmit="return confirm('¿Eliminar el logro «{{ achievement.name }}»? Esta acción no se puede deshacer.')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_achievement_' ~ achievement.id) }}">
                                        <button type="submit" class="p-2 rounded-lg bg-red-900/20 hover:bg-red-900/40 text-red-500 hover:text-red-400 transition-all" title="Eliminar">
                                            <span class="material-symbols-outlined text-base">delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="px-6 py-16 text-center text-slate-500">
                                <span class="material-symbols-outlined text-4xl block mb-2">emoji_events</span>
                                No hay logros todavía.
                                <a href="{{ path('admin_achievements_new') }}" class="text-red-500 hover:underline ml-1">Crear el primero</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

</div>
{% endblock %}
