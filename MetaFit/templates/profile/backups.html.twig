{% extends 'base.html.twig' %}

{% block title %}Backups - MetaFit AI{% endblock %}

{% block body %}
    <div class="bg-background-dark text-white">
        <div class="max-w-4xl mx-auto pt-14 md:pt-16">

            <a href="{{ path('profile_index') }}" class="inline-flex items-center gap-2 text-slate-400 hover:text-white mb-8 transition-all">
                <span class="material-symbols-outlined text-xl">arrow_back</span>
                Volver al Perfil
            </a>

            <div class="mb-12">
                <div class="flex items-center gap-4 mb-4">
                    <div class="h-1 w-12 bg-primary"></div>
                    <span class="text-primary font-bold tracking-[0.3em] uppercase text-sm">Datos</span>
                </div>
                <h1 class="text-5xl font-black italic uppercase tracking-tighter">
                    Backup y Restauración
                </h1>
            </div>

            {# CREAR BACKUP #}
            <div class="bg-[#0d1117] border border-slate-800 rounded-2xl p-8 mb-12">
                <h3 class="text-2xl font-black uppercase mb-6">Crear Nuevo Backup</h3>
                <p class="text-slate-400 mb-6">Descarga una copia completa de tus datos en formato JSON</p>

                <form method="POST" class="space-y-6">
                    <input type="hidden" name="action" value="create_backup">

                    {# TIPO DE BACKUP #} 
                    <div>
                        <label class="block text-sm font-bold uppercase tracking-widest text-slate-300 mb-4">Tipo de Backup</label>
                        <div class="space-y-3">
                            <label class="flex items-center gap-3 p-4 border border-slate-700 rounded-lg cursor-pointer hover:border-primary transition-all">
                                <input type="radio" name="backup_type" value="full" checked required>
                                <div>
                                    <p class="font-bold">Backup Completo</p>
                                    <p class="text-xs text-slate-400">Todos tus datos personales, rutinas, entrenamientos, comidas y logros</p>
                                </div>
                            </label>
                            <label class="flex items-center gap-3 p-4 border border-slate-700 rounded-lg cursor-pointer hover:border-primary transition-all">
                                <input type="radio" name="backup_type" value="routines" required>
                                <div>
                                    <p class="font-bold">Solo Rutinas</p>
                                    <p class="text-xs text-slate-400">Todas tus rutinas de entrenamiento con ejercicios</p>
                                </div>
                            </label>
                            <label class="flex items-center gap-3 p-4 border border-slate-700 rounded-lg cursor-pointer hover:border-primary transition-all">
                                <input type="radio" name="backup_type" value="trainings" required>
                                <div>
                                    <p class="font-bold">Solo Entrenamientos</p>
                                    <p class="text-xs text-slate-400">Historial completo de tus entrenamientos</p>
                                </div>
                            </label>
                        </div>
                    </div>

                    {# INCLUIR #}
                    <div>
                        <label class="block text-sm font-bold uppercase tracking-widest text-slate-300 mb-4">Incluir en Backup</label>
                        <div class="space-y-3">
                            <label class="flex items-center gap-3 p-3 bg-slate-900/50 border border-slate-700 rounded-lg cursor-pointer">
                                <input type="checkbox" name="include_personal_data" checked>
                                <span>Datos personales (nombre, edad, peso, etc.)</span>
                            </label>
                            <label class="flex items-center gap-3 p-3 bg-slate-900/50 border border-slate-700 rounded-lg cursor-pointer">
                                <input type="checkbox" name="include_routines" checked>
                                <span>Rutinas de entrenamiento</span>
                            </label>
                            <label class="flex items-center gap-3 p-3 bg-slate-900/50 border border-slate-700 rounded-lg cursor-pointer">
                                <input type="checkbox" name="include_trainings" checked>
                                <span>Historial de entrenamientos</span>
                            </label>
                            <label class="flex items-center gap-3 p-3 bg-slate-900/50 border border-slate-700 rounded-lg cursor-pointer">
                                <input type="checkbox" name="include_meals" checked>
                                <span>Comidas y nutrición</span>
                            </label>
                            <label class="flex items-center gap-3 p-3 bg-slate-900/50 border border-slate-700 rounded-lg cursor-pointer">
                                <input type="checkbox" name="include_achievements" checked>
                                <span>Logros desbloqueados</span>
                            </label>
                        </div>
                    </div>

                    <div class="flex gap-4">
                        <button type="submit" class="flex-1 bg-primary hover:bg-primary/80 text-white px-6 py-3 rounded-xl transition-all font-bold uppercase">
                            📥 Crear Backup Ahora
                        </button>
                    </div>
                </form>
            </div>

            {# INFORMACIÓN #}
            <div class="bg-gradient-to-r from-blue-500/10 to-transparent border border-blue-500/30 rounded-2xl p-8 mb-12">
                <div class="flex gap-4">
                    <span class="material-symbols-outlined text-3xl text-blue-400 flex-shrink-0">info</span>
                    <div>
                        <h3 class="font-black uppercase text-lg mb-2">Información sobre Backups</h3>
                        <ul class="text-sm text-slate-300 space-y-2">
                            <li>• Los backups expiran después de 30 días</li>
                            <li>• Todos los datos están encriptados</li>
                            <li>• Puedes descargar tus backups en formato JSON</li>
                            <li>• No hay límite de backups que puedas crear</li>
                            <li>• Los datos solo son accesibles por ti</li>
                        </ul>
                    </div>
                </div>
            </div>

            {# BACKUPS EXISTENTES #}
            {% if backups|length > 0 %}
                <div class="bg-[#0d1117] border border-slate-800 rounded-2xl p-8">
                    <h3 class="text-2xl font-black uppercase mb-6">Tus Backups</h3>
                    <div class="space-y-4">
                        {% for backup in backups %}
                            <div class="border border-slate-700 rounded-xl p-6 bg-slate-900/30">
                                <div class="flex items-center justify-between mb-3">
                                    <div>
                                        <p class="font-black uppercase">{{ backup.getFileName() }}</p>
                                        <p class="text-sm text-slate-400">{{ backup.getCreatedAt()|date('d/m/Y H:i') }}</p>
                                    </div>
                                    <span class="text-sm bg-primary/30 text-primary px-3 py-1 rounded-lg font-bold capitalize">
                                        {{ backup.getBackupType() }}
                                    </span>
                                </div>

                                <div class="grid md:grid-cols-5 gap-2 mb-4 text-xs text-slate-400">
                                    <div>
                                        <p class="text-slate-500">Tamaño</p>
                                        <p class="font-bold text-white">{{ backup.getFileSizeMB() }} MB</p>
                                    </div>
                                    <div>
                                        <p class="text-slate-500">Datos Personales</p>
                                        <p class="font-bold text-white">{{ backup.isIncludePersonalData() ? '✓' : '✗' }}</p>
                                    </div>
                                    <div>
                                        <p class="text-slate-500">Rutinas</p>
                                        <p class="font-bold text-white">{{ backup.isIncludeRoutines() ? '✓' : '✗' }}</p>
                                    </div>
                                    <div>
                                        <p class="text-slate-500">Entrenamientos</p>
                                        <p class="font-bold text-white">{{ backup.isIncludeTrainings() ? '✓' : '✗' }}</p>
                                    </div>
                                    <div>
                                        <p class="text-slate-500">Expira</p>
                                        <p class="font-bold text-white">{{ backup.getExpiresAt()|date('d/m/Y') }}</p>
                                    </div>
                                </div>

                                <div class="flex gap-2">
                                    <button type="button" class="flex-1 bg-primary hover:bg-primary/80 text-white px-4 py-2 rounded-lg font-bold uppercase transition-all">
                                        📥 Descargar
                                    </button>
                                    <form method="POST" class="inline">
                                        <input type="hidden" name="action" value="delete_backup">
                                        <input type="hidden" name="backup_id" value="{{ backup.getId() }}">
                                        <button type="submit" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg font-bold uppercase transition-all">
                                            🗑️ Eliminar
                                        </button>
                                    </form>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% else %}
                <div class="bg-slate-900/50 border border-slate-700 rounded-2xl p-8 text-center">
                    <p class="text-slate-400">No tienes backups creados. ¡Crea uno ahora para proteger tus datos!</p>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
