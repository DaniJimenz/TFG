{% extends 'base.html.twig' %}

{% block title %}Cambiar Contraseña - MetaFit AI{% endblock %}

{% block body %}
    <div class="bg-background-dark text-white min-h-screen flex flex-col">
        <div class="max-w-2xl mx-auto pt-8 md:pt-10 px-4 flex-1">

            <a href="{{ path('profile_index') }}" class="inline-flex items-center gap-2 text-slate-400 hover:text-white mb-8 transition-all">
                <span class="material-symbols-outlined text-xl">arrow_back</span>
                Volver al Perfil
            </a>

            <div class="mb-6">
                <div class="flex items-center gap-3 mb-2">
                    <div class="h-1 w-8 bg-primary"></div>
                    <span class="text-primary font-bold tracking-[0.2em] uppercase text-xs">Seguridad</span>
                </div>
                <h1 class="text-4xl md:text-5xl font-black italic uppercase tracking-tighter">
                    Contraseña
                </h1>
            </div>

            {# ADVERTENCIA #}
            <div class="bg-gradient-to-r from-blue-500/10 to-transparent border border-blue-500/30 rounded-xl p-3 mb-4">
                <div class="flex gap-2">
                    <span class="material-symbols-outlined text-lg text-blue-400 flex-shrink-0">lock_outline</span>
                    <div>
                        <p class="font-bold text-sm">Seguridad</p>
                        <p class="text-xs text-slate-400 mt-0.5">Mínimo 8 caracteres con letras, números y símbolos.</p>
                    </div>
                </div>
            </div>

            <form method="POST" class="bg-[#0d1117] border border-slate-800 rounded-xl p-4 space-y-3">

                {# CONTRASEÑA ACTUAL #}
                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-300 mb-1">Contraseña Actual</label>
                    <input type="password" name="current_password" required class="w-full bg-slate-900 border border-slate-700 rounded px-2 py-2 text-sm text-white focus:outline-none focus:border-primary transition-all" placeholder="••••••••">
                </div>

                {# NUEVA CONTRASEÑA #}
                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-300 mb-1">Nueva Contraseña</label>
                    <input type="password" name="new_password" required minlength="8" class="w-full bg-slate-900 border border-slate-700 rounded px-2 py-2 text-sm text-white focus:outline-none focus:border-primary transition-all" placeholder="••••••••">
                </div>

                {# CONFIRMAR CONTRASEÑA #}
                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-300 mb-1">Confirmar Nueva Contraseña</label>
                    <input type="password" name="confirm_password" required minlength="8" class="w-full bg-slate-900 border border-slate-700 rounded px-2 py-2 text-sm text-white focus:outline-none focus:border-primary transition-all" placeholder="••••••••">
                </div>

                {# BOTONES #}
                <div class="flex gap-3 pt-2">
                    <a href="{{ path('profile_index') }}" class="flex-1 bg-slate-800 hover:bg-slate-700 text-white px-4 py-2 rounded transition-all font-bold uppercase text-sm text-center">
                        Cancelar
                    </a>
                    <button type="submit" class="flex-1 bg-primary hover:bg-primary/80 text-white px-4 py-2 rounded transition-all font-bold uppercase text-sm">
                        ✓ Cambiar
                    </button>
                </div>

            </form>
        </div>
    </div>
{% endblock %}
