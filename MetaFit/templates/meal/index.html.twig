{% extends 'base.html.twig' %}

{% block title %}Mis Comidas - MetaFit AI{% endblock %}

{% block body %}
<div class="bg-background-dark text-white">
    <div class="max-w-6xl mx-auto pt-14 md:pt-16">

        {# HEADER #}
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-3 md:gap-4 mb-6 md:mb-8">
            <div>
                <div class="flex items-center gap-4 mb-4">
                    <div class="h-1 w-12 bg-primary"></div>
                    <span class="text-primary font-bold tracking-[0.3em] uppercase text-sm">Registro de Comidas</span>
                </div>
                <h1 class="text-5xl font-black italic uppercase tracking-tighter mb-2">
                    Mi <span class="text-primary">Nutrición</span>
                </h1>
                <p class="text-gray-400 text-lg font-light">
                    Controla tu ingesta diaria de macros y calorías
                </p>
            </div>
            <a href="{{ path('meal_new') }}" class="bg-primary hover:bg-primary/90 text-white px-6 py-3 rounded-xl transition-all font-bold text-sm uppercase flex items-center gap-2 w-fit">
                <span class="material-symbols-outlined">add</span>
                Nueva Comida
            </a>
        </div>

        {# RESUMEN DE HOY #}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-2 sm:gap-3 mb-6 md:mb-8">
            <div class="bg-[#0d1117] border border-slate-800 p-3 sm:p-4 md:p-5 rounded-lg md:rounded-2xl">
                <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest mb-2">Calorías</p>
                <p class="text-3xl font-black italic text-primary">0 <span class="text-sm">kcal</span></p>
            </div>
            <div class="bg-[#0d1117] border border-slate-800 p-6 rounded-2xl">
                <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest mb-2">Proteínas</p>
                <p class="text-3xl font-black italic text-accent-purple">0 <span class="text-sm">g</span></p>
            </div>
            <div class="bg-[#0d1117] border border-slate-800 p-6 rounded-2xl">
                <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest mb-2">Carbohidratos</p>
                <p class="text-3xl font-black italic">0 <span class="text-sm">g</span></p>
            </div>
            <div class="bg-[#0d1117] border border-slate-800 p-6 rounded-2xl">
                <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest mb-2">Grasas</p>
                <p class="text-3xl font-black italic">0 <span class="text-sm">g</span></p>
            </div>
        </div>

        {# LISTA DE COMIDAS #}
        {% if meals is not empty %}
            <div class="space-y-4">
                {% for meal in meals %}
                    <div class="bg-[#0d1117] border border-slate-800 hover:border-primary/50 p-6 rounded-2xl transition-all">
                        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                            <div class="flex-1">
                                <div class="flex items-center gap-3 mb-2">
                                    <span class="material-symbols-outlined text-primary">
                                        {% if meal.foodType == 'desayuno' %}breakfast_dining
                                        {% elseif meal.foodType == 'comida' %}lunch_dining
                                        {% elseif meal.foodType == 'merienda' %}local_cafe
                                        {% else %}dinner_dining{% endif %}
                                    </span>
                                    <span class="text-primary font-bold uppercase text-sm">{{ meal.foodType }}</span>
                                </div>
                                <h3 class="text-lg font-bold mb-3">{{ meal.registerDate|date('H:i') }}</h3>
                                
                                <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                                    <div>
                                        <p class="text-slate-500 text-xs uppercase tracking-wider">Calorías</p>
                                        <p class="text-xl font-bold">{{ meal.caloriesTotal|default('-') }}</p>
                                    </div>
                                    <div>
                                        <p class="text-slate-500 text-xs uppercase tracking-wider">Proteínas</p>
                                        <p class="text-xl font-bold">{{ meal.proteinesG|default('-') }}g</p>
                                    </div>
                                    <div>
                                        <p class="text-slate-500 text-xs uppercase tracking-wider">Carbos</p>
                                        <p class="text-xl font-bold">{{ meal.carbohidratsG|default('-') }}g</p>
                                    </div>
                                    <div>
                                        <p class="text-slate-500 text-xs uppercase tracking-wider">Grasas</p>
                                        <p class="text-xl font-bold">{{ meal.fatsG|default('-') }}g</p>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="flex gap-2">
                                <a href="{{ path('meal_edit', {'id': meal.id}) }}" class="border border-slate-700 hover:bg-slate-800 text-slate-400 hover:text-white px-4 py-2 rounded-lg transition-all font-bold text-xs uppercase">
                                    Editar
                                </a>
                                <form method="POST" action="{{ path('meal_delete', {'id': meal.id}) }}" style="display: inline;" onsubmit="return confirm('¿Estás seguro?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_meal_' ~ meal.id) }}">
                                    <button type="submit" class="border border-red-700/50 hover:bg-red-500/10 text-red-500 px-4 py-2 rounded-lg transition-all font-bold text-xs uppercase">
                                        Eliminar
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="bg-[#0d1117] border border-slate-800 p-12 rounded-2xl text-center">
                <span class="material-symbols-outlined text-slate-600 text-5xl mb-4 block">restaurant</span>
                <h3 class="text-xl font-bold mb-2">No hay comidas registradas</h3>
                <p class="text-slate-400 mb-6">Usa el botón "Nueva Comida" en la parte superior para comenzar</p>
            </div>
        {% endif %}

    </div>
</div>
{% endblock %}
