{% extends 'base.html.twig' %}

{% block title %}Editar Perfil - MetaFit AI{% endblock %}

{% block body %}
    <div class="bg-background-dark text-white">
        <div class="max-w-full mx-auto px-4 sm:px-6 pt-6 md:pt-8">

            {# HEADER #}
            <a href="{{ path('profile_index') }}" class="inline-flex items-center gap-2 text-slate-400 hover:text-white mb-8 transition-all">
                <span class="material-symbols-outlined text-xl">arrow_back</span>
                Volver al Perfil
            </a>

            <div class="mb-12">
                <div class="flex items-center gap-4 mb-4">
                    <div class="h-1 w-12 bg-primary"></div>
                    <span class="text-primary font-bold tracking-[0.3em] uppercase text-sm">Mi Cuenta</span>
                </div>
                <h1 class="text-5xl font-black italic uppercase tracking-tighter">
                    Información Personal
                </h1>
            </div>

            {# FORMULARIO #}
            <form method="POST" class="bg-[#0d1117] border border-slate-800 rounded-2xl p-8 space-y-6">

                {# NOMBRE Y APELLIDO #}
                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-bold uppercase tracking-widest text-slate-300 mb-2">Nombre</label>
                        <input type="text" name="name" value="{{ user.getName() }}" required class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-all">
                    </div>
                    <div>
                        <label class="block text-sm font-bold uppercase tracking-widest text-slate-300 mb-2">Apellido</label>
                        <input type="text" name="lastname" value="{{ user.getLastname() }}" required class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-all">
                    </div>
                </div>

                {# DATOS FÍSICOS #}
                <div class="bg-slate-900/50 border border-slate-700 rounded-xl p-6">
                    <h3 class="text-lg font-black uppercase mb-4">Datos Físicos</h3>
                    <div class="grid md:grid-cols-3 gap-6">
                        <div>
                            <label class="block text-sm font-bold uppercase tracking-widest text-slate-300 mb-2">Edad (años)</label>
                            <input type="number" name="age" value="{{ user.getAge() ?? '' }}" min="13" max="120" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-all">
                        </div>
                        <div>
                            <label class="block text-sm font-bold uppercase tracking-widest text-slate-300 mb-2">Altura (cm)</label>
                            <input type="number" name="height" value="{{ user.getHeight() ?? '' }}" step="0.1" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-all">
                        </div>
                        <div>
                            <label class="block text-sm font-bold uppercase tracking-widest text-slate-300 mb-2">Peso Actual (kg)</label>
                            <input type="number" name="actual_weight" value="{{ user.getActualWeight() ?? '' }}" step="0.5" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-all">
                        </div>
                    </div>
                </div>

                {# GÉNERO #}
                <div>
                    <label class="block text-sm font-bold uppercase tracking-widest text-slate-300 mb-2">Género</label>
                    <select name="gender" class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-all">
                        <option value="">Seleccionar...</option>
                        <option value="M" {% if user.getGender() == 'M' %}selected{% endif %}>Masculino</option>
                        <option value="F" {% if user.getGender() == 'F' %}selected{% endif %}>Femenino</option>
                        <option value="O" {% if user.getGender() == 'O' %}selected{% endif %}>Otro</option>
                    </select>
                </div>

                {# OBJETIVO #}
                <div>
                    <label class="block text-sm font-bold uppercase tracking-widest text-slate-300 mb-2">Objetivo Principal</label>
                    <select name="purpose" class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-all">
                        <option value="">Seleccionar...</option>
                        <option value="Ganar Masa" {% if user.getPurpose() == 'Ganar Masa' %}selected{% endif %}>Ganar Masa Muscular</option>
                        <option value="Perder Peso" {% if user.getPurpose() == 'Perder Peso' %}selected{% endif %}>Perder Peso</option>
                        <option value="Resistencia" {% if user.getPurpose() == 'Resistencia' %}selected{% endif %}>Mejorar Resistencia</option>
                        <option value="Fuerza" {% if user.getPurpose() == 'Fuerza' %}selected{% endif %}>Aumentar Fuerza</option>
                        <option value="Tonificacion" {% if user.getPurpose() == 'Tonificacion' %}selected{% endif %}>Tonificación</option>
                        <option value="General" {% if user.getPurpose() == 'General' %}selected{% endif %}>Salud General</option>
                    </select>
                </div>

                {# NIVEL DE ACTIVIDAD #}
                <div>
                    <label class="block text-sm font-bold uppercase tracking-widest text-slate-300 mb-2">Nivel de Actividad</label>
                    <select name="activity_level" class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-all">
                        <option value="">Seleccionar...</option>
                        <option value="Sedentario" {% if user.getActivityLevel() == 'Sedentario' %}selected{% endif %}>Sedentario (poco ejercicio)</option>
                        <option value="Leve" {% if user.getActivityLevel() == 'Leve' %}selected{% endif %}>Leve (1-3 días/semana)</option>
                        <option value="Moderado" {% if user.getActivityLevel() == 'Moderado' %}selected{% endif %}>Moderado (3-5 días/semana)</option>
                        <option value="Intenso" {% if user.getActivityLevel() == 'Intenso' %}selected{% endif %}>Intenso (6-7 días/semana)</option>
                        <option value="Muy Intenso" {% if user.getActivityLevel() == 'Muy Intenso' %}selected{% endif %}>Muy Intenso (atletismo/profesional)</option>
                    </select>
                </div>

                {# BOTONES #}
                <div class="flex gap-4 pt-6">
                    <a href="{{ path('profile_index') }}" class="flex-1 bg-slate-800 hover:bg-slate-700 text-white px-6 py-3 rounded-xl transition-all font-bold uppercase text-center">
                        Cancelar
                    </a>
                    <button type="submit" class="flex-1 bg-primary hover:bg-primary/80 text-white px-6 py-3 rounded-xl transition-all font-bold uppercase">
                        ✓ Guardar Cambios
                    </button>
                </div>

            </form>
        </div>
    </div>
{% endblock %}
