{% extends 'base.html.twig' %}

{% block title %}Dashboard MetaFit AI{% endblock %}

{% block body %}
    <div class="bg-background-dark text-white min-h-screen">
        <div class="max-w-7xl mx-auto px-2 sm:px-4 md:px-6 pt-6 md:pt-8 pb-8">

            {# HEADER CON BIENVENIDA Y BOTÓN #}
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
                <div class="flex-1">
                    <div class="text-sm font-bold text-slate-500 uppercase tracking-widest mb-2">
                        📅 {{ 'now'|date('d \\d\\e F') }} • <span class="text-primary">{{ user.objective|default('Objetivo General') }}</span>
                    </div>
                    <h1 class="text-4xl sm:text-5xl md:text-6xl font-black italic uppercase tracking-tighter text-white">
                        ¡Hola, <span class="text-primary">{{ user.name|split(' ')[0] }}</span>! 👋
                    </h1>
                    <p class="text-slate-400 text-sm md:text-base mt-2">
                        Tu ecosistema de entrenamiento está listo para revolucionar tus resultados
                    </p>
                </div>
                <div class="flex flex-col gap-2 md:gap-3">
                    <a href="{{ path('routine_new') }}" class="bg-primary hover:bg-primary/90 text-white px-6 py-3 rounded-xl transition-all font-bold text-sm uppercase flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-base">play_arrow</span>
                        Comenzar Rutina
                    </a>
                    <a href="{{ path('meal_new') }}" class="border border-primary/50 hover:bg-primary/10 text-primary px-6 py-3 rounded-xl transition-all font-bold text-sm uppercase flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-base">add</span>
                        Nueva Comida
                    </a>
                </div>
            </div>

            {# GRID RESPONSIVO: STATS PERSONALES + PREMIUM #}
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 md:gap-6 mb-8">
                
                {# STATS PERSONALES (Izquierda - 2 columnas en desktop) #}
                <div class="lg:col-span-2">
                    <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-4 gap-2 md:gap-3">
                        <div class="bg-[#0d1117] border border-slate-800 p-3 sm:p-4 rounded-lg hover:border-primary/30 transition-all">
                            <p class="text-slate-500 text-[9px] font-bold uppercase tracking-widest mb-2">Peso</p>
                            <p class="text-2xl sm:text-3xl font-black italic text-white">{{ user.actualWeight|default('--') }}<span class="text-primary text-xs ml-1">KG</span></p>
                        </div>
                        <div class="bg-[#0d1117] border border-slate-800 p-3 sm:p-4 rounded-lg hover:border-primary/30 transition-all">
                            <p class="text-slate-500 text-[9px] font-bold uppercase tracking-widest mb-2">Altura</p>
                            <p class="text-2xl sm:text-3xl font-black italic text-white">{{ user.height|default('--') }}<span class="text-primary text-xs ml-1">M</span></p>
                        </div>
                        <div class="bg-[#0d1117] border border-slate-800 p-3 sm:p-4 rounded-lg hover:border-primary/30 transition-all">
                            <p class="text-slate-500 text-[9px] font-bold uppercase tracking-widest mb-2">Edad</p>
                            <p class="text-2xl sm:text-3xl font-black italic text-white">{{ user.age|default('--') }}<span class="text-primary text-xs ml-1">A</span></p>
                        </div>

                        {% set imc = 0 %}
                        {% if user.height and user.actualWeight and user.height > 0 %}
                            {% set imc = user.actualWeight / ((user.height / 100) * (user.height / 100)) %}
                        {% endif %}

                        <div class="bg-primary/20 border border-primary/50 p-3 sm:p-4 rounded-lg">
                            <p class="text-primary text-[9px] font-bold uppercase tracking-widest mb-2">Tu IMC</p>
                            <p class="text-2xl sm:text-3xl font-black italic text-primary">{{ imc > 0 ? imc|number_format(1) : '--' }}</p>
                        </div>
                    </div>
                </div>

                {# CARD PREMIUM (Derecha) #}
                <div class="bg-gradient-to-br from-green-500/20 to-green-600/10 border border-green-500/30 p-5 md:p-6 rounded-2xl flex flex-col justify-between">
                    <div>
                        <div class="flex items-center justify-between mb-4">
                            <span class="text-primary font-bold text-xs uppercase tracking-widest">🚀 Premium Active</span>
                            <span class="material-symbols-outlined text-2xl text-green-400">verified</span>
                        </div>
                        <h3 class="text-lg font-black text-white mb-2">MetaFit Premium</h3>
                        <p class="text-slate-300 text-xs leading-relaxed mb-4">
                            Acceso ilimitado a todas las rutinas, IA Coach y análisis avanzado de progreso
                        </p>
                    </div>
                    <button class="bg-primary hover:bg-primary/90 text-white px-4 py-2 rounded-lg transition-all font-bold text-xs uppercase w-full">
                        Explorar Beneficios →
                    </button>
                </div>
            </div>

            {# STATS ENTRENAMIENTOS #}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6 mb-8">
                <div class="bg-gradient-to-br from-blue-500/20 to-transparent border border-blue-500/30 p-4 sm:p-5 md:p-6 rounded-lg md:rounded-2xl hover:border-blue-500/50 transition-all">
                    <div class="flex items-center justify-between mb-3">
                        <p class="text-slate-400 text-[9px] md:text-[10px] font-bold uppercase tracking-widest">💪 Entrenamientos</p>
                    </div>
                    <p class="text-3xl sm:text-4xl font-black italic text-blue-400">{{ stats.totalTrainings }}</p>
                    <p class="text-slate-500 text-[11px] mt-2">✓ {{ stats.completedTrainings }} completados</p>
                </div>

                <div class="bg-gradient-to-br from-orange-500/20 to-transparent border border-orange-500/30 p-4 sm:p-5 md:p-6 rounded-lg md:rounded-2xl hover:border-orange-500/50 transition-all">
                    <div class="flex items-center justify-between mb-3">
                        <p class="text-slate-400 text-[9px] md:text-[10px] font-bold uppercase tracking-widest">⏱️ Tiempo Total</p>
                    </div>
                    <p class="text-3xl sm:text-4xl font-black italic text-orange-400">{{ (stats.totalMinutes / 60)|number_format(1) }}</p>
                    <p class="text-slate-500 text-[11px] mt-2">Horas de entrenamiento</p>
                </div>

                <div class="bg-gradient-to-br from-green-500/20 to-transparent border border-green-500/30 p-4 sm:p-5 md:p-6 rounded-lg md:rounded-2xl hover:border-green-500/50 transition-all">
                    <div class="flex items-center justify-between mb-3">
                        <p class="text-slate-400 text-[9px] md:text-[10px] font-bold uppercase tracking-widest">🔥 Calorías</p>
                    </div>
                    <p class="text-3xl sm:text-4xl font-black italic text-green-400">{{ stats.totalCalories|number_format(0) }}</p>
                    <p class="text-slate-500 text-[11px] mt-2">Total quemadas</p>
                </div>
            </div>

            {# RACHA Y ESTADÍSTICAS #}
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 mb-8">
                <div class="bg-[#0d1117] border border-slate-800 p-4 rounded-lg hover:border-primary/30 transition-all">
                    <p class="text-slate-500 text-[9px] font-bold uppercase tracking-widest mb-2">🔥 Racha</p>
                    <p class="text-2xl sm:text-3xl font-black italic text-primary">{{ stats.currentStreak }}</p>
                    <p class="text-slate-500 text-[11px] mt-1">días</p>
                </div>

                <div class="bg-[#0d1117] border border-slate-800 p-4 rounded-lg hover:border-slate-600/50 transition-all">
                    <p class="text-slate-500 text-[9px] font-bold uppercase tracking-widest mb-2">⭐ Máxima</p>
                    <p class="text-2xl sm:text-3xl font-black italic text-slate-300">{{ stats.longestStreak }}</p>
                    <p class="text-slate-500 text-[11px] mt-1">días</p>
                </div>

                <div class="bg-[#0d1117] border border-slate-800 p-4 rounded-lg hover:border-slate-600/50 transition-all">
                    <p class="text-slate-500 text-[9px] font-bold uppercase tracking-widest mb-2">📊 Peso Prom.</p>
                    <p class="text-2xl sm:text-3xl font-black italic">{{ stats.avgWeight }}</p>
                    <p class="text-slate-500 text-[11px] mt-1">KG</p>
                </div>

                <div class="bg-[#0d1117] border border-slate-800 p-4 rounded-lg hover:border-primary/30 transition-all">
                    <p class="text-slate-500 text-[9px] font-bold uppercase tracking-widest mb-2">⚡ Nivel XP</p>
                    <p class="text-2xl sm:text-3xl font-black italic text-primary">{{ user.level }}</p>
                    <p class="text-slate-500 text-[11px] mt-1">{{ user.pointsXp }} XP</p>
                </div>
            </div>

            {# ÚLTIMAS RUTINAS Y NUTRICIÓN #}
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 md:gap-6 mb-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
                <div class="bg-[#0d1117] border border-slate-800 p-6 rounded-2xl">
                    <h3 class="text-lg font-black italic uppercase mb-4">Última Semana</h3>
                    <div class="space-y-3">
                        <div class="flex justify-between items-center">
                            <span class="text-slate-400">Entrenamientos:</span>
                            <span class="text-2xl font-black text-primary">{{ stats.weekTrainings }}</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-slate-400">Tiempo:</span>
                            <span class="text-xl font-black">{{ (stats.weekMinutes / 60)|number_format(1) }}h</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-slate-400">Calorías:</span>
                            <span class="text-xl font-black text-green-400">{{ stats.weekCalories|number_format(0) }}</span>
                        </div>
                    </div>
                </div>

                <div class="bg-[#0d1117] border border-slate-800 p-6 rounded-2xl">
                    <h3 class="text-lg font-black italic uppercase mb-4">Grupos Musculares</h3>
                    <div class="space-y-3">
                        <div class="flex justify-between items-center">
                            <span class="text-slate-400">Más entrenado:</span>
                            <span class="text-xl font-black text-primary">{{ stats.topMuscleGroup }}</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-slate-400">Ejercicio favorito:</span>
                            <span class="text-sm font-black line-clamp-1">{{ stats.favoriteExercise }}</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-slate-400">Entrenamientos mes:</span>
                            <span class="text-xl font-black">{{ stats.monthTrainings }}</span>
                        </div>
                    </div>
                </div>
            </div>

            {# ENTRENAMIENTOS RECIENTES #}
            {% if recentTrainings|length > 0 %}
            <div class="mb-12">
                <h2 class="text-3xl font-black italic uppercase tracking-tighter mb-6">Entrenamientos <span class="text-primary">Recientes</span></h2>
                <div class="space-y-3">
                    {% for training in recentTrainings %}
                        <div class="bg-[#0d1117] border border-slate-800 p-4 rounded-xl hover:border-slate-700 transition-all flex items-center justify-between">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 bg-primary/20 rounded-lg flex items-center justify-center text-xl">
                                    {% if training.getExercise().getMuscularGroup() == 'Pecho' %}
                                        💪
                                    {% elseif training.getExercise().getMuscularGroup() == 'Espalda' %}
                                        🔙
                                    {% elseif training.getExercise().getMuscularGroup() == 'Piernas' %}
                                        🦵
                                    {% elseif training.getExercise().getMuscularGroup() == 'Core' %}
                                        🎯
                                    {% else %}
                                        🏋️
                                    {% endif %}
                                </div>
                                <div>
                                    <p class="font-black italic text-white">{{ training.getExercise().getName() }}</p>
                                    <p class="text-slate-500 text-xs">{{ training.getDate()|date('d/m/Y H:i') }}</p>
                                </div>
                            </div>
                            <div class="text-right">
                                <p class="text-sm font-bold text-primary">{{ training.getDurationMinutes() }} min</p>
                                <p class="text-xs text-slate-500">{{ training.getWeight() }} kg</p>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            {# RUTINA #}
            <div class="mb-8">
                <h2 class="text-3xl font-black italic uppercase tracking-tighter mb-8">Tu Rutina <span class="text-primary">Personalizada</span></h2>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    {% for ejercicio in rutina %}
                        <div class="group bg-[#0d1117] border border-slate-800 rounded-3xl overflow-hidden hover:border-primary/50 transition-all">
                            <div class="relative h-48 overflow-hidden">
                                <img src="{{ ejercicio.getUrlImage()|default('https://images.unsplash.com/photo-1534438327276-14e5300c3a48') }}" class="w-full h-full object-cover">
                                <div class="absolute top-4 left-4">
                                    <span class="bg-black/80 text-white text-[10px] font-black px-3 py-1 rounded-lg uppercase">
                                        {{ ejercicio.getMuscularGroup() }}
                                    </span>
                                </div>
                            </div>
                            <div class="p-6">
                                <h3 class="text-xl font-black italic uppercase text-white mb-2">{{ ejercicio.getName() }}</h3>
                                <p class="text-slate-500 text-sm line-clamp-2">{{ ejercicio.getDescription() }}</p>
                                <div class="mt-6 pt-4 border-t border-slate-800/50 flex justify-between items-center text-[10px] font-black uppercase tracking-tighter">
                                    <span class="text-slate-400">Esfuerzo</span>
                                    <span class="text-primary">{{ ejercicio.getDifficulty() }}</span>
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <div class="col-span-full py-20 text-center border-2 border-dashed border-slate-800 rounded-3xl">
                            <p class="text-slate-500 italic">No hay ejercicios para nivel "{{ user.activityLevel|default('Bajo') }}".</p>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
