{% extends 'base.html.twig' %}

{% block title %}Cambiar Contraseña - MetaFit AI{% endblock %}

{% block body %}
    <div class="bg-background-dark text-white min-h-screen flex flex-col">
        <div class="max-w-2xl mx-auto pt-8 md:pt-10 px-4 flex-1">

            <a href="{{ path('profile_index') }}" class="inline-flex items-center gap-2 text-slate-400 hover:text-white mb-8 transition-all">
                <span class="material-symbols-outlined text-xl">arrow_back</span>
                Volver al Perfil
            </a>

            <div class="mb-6">
                <div class="flex items-center gap-3 mb-2">
                    <div class="h-1 w-8 bg-primary"></div>
                    <span class="text-primary font-bold tracking-[0.2em] uppercase text-xs">Seguridad</span>
                </div>
                <h1 class="text-4xl md:text-5xl font-black italic uppercase tracking-tighter">
                    Contraseña
                </h1>
            </div>

            {# ADVERTENCIA #}
            <div class="bg-gradient-to-r from-blue-500/10 to-transparent border border-blue-500/30 rounded-xl p-3 mb-4">
                <div class="flex gap-2">
                    <span class="material-symbols-outlined text-lg text-blue-400 flex-shrink-0">lock_outline</span>
                    <div>
                        <p class="font-bold text-sm">Seguridad</p>
                        <p class="text-xs text-slate-400 mt-0.5">Mínimo 8 caracteres con letras, números y símbolos.</p>
                    </div>
                </div>
            </div>

            {# MENSAJES DE ERROR #}
            {% for message in app.flashes('error') %}
                <div class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-xl p-3 mb-4 text-sm font-bold flex items-center gap-2">
                    <span class="material-symbols-outlined text-lg">error</span>
                    {{ message }}
                </div>
            {% endfor %}

            <form method="POST" class="bg-[#0d1117] border border-slate-800 rounded-xl p-4 space-y-3">
                
                <input type="hidden" name="_token" value="{{ csrf_token('change_password') }}">

                {# CONTRASEÑA ACTUAL #}
                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-300 mb-1">Contraseña Actual</label>
                    <div class="relative">
                        <input type="password" id="current_password" name="current_password" required class="w-full bg-slate-900 border border-slate-700 rounded px-3 py-2 pr-10 text-sm text-white focus:outline-none focus:border-primary transition-all" placeholder="••••••••">
                        <button type="button" onclick="togglePassword('current_password', 'icon_current')" class="absolute inset-y-0 right-0 flex items-center pr-3 text-slate-400 hover:text-white transition-colors" title="Mostrar/Ocultar contraseña">
                            <span class="material-symbols-outlined text-[18px]" id="icon_current">visibility</span>
                        </button>
                    </div>
                </div>

                {# NUEVA CONTRASEÑA #}
                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-300 mb-1">Nueva Contraseña</label>
                    <div class="relative">
                        <input type="password" id="new_password" name="new_password" required minlength="8" class="w-full bg-slate-900 border border-slate-700 rounded px-3 py-2 pr-10 text-sm text-white focus:outline-none focus:border-primary transition-all" placeholder="••••••••" onkeyup="checkPasswords()">
                        <button type="button" onclick="togglePassword('new_password', 'icon_new')" class="absolute inset-y-0 right-0 flex items-center pr-3 text-slate-400 hover:text-white transition-colors" title="Mostrar/Ocultar contraseña">
                            <span class="material-symbols-outlined text-[18px]" id="icon_new">visibility</span>
                        </button>
                    </div>
                </div>

                {# CONFIRMAR CONTRASEÑA #}
                <div>
                    <label class="block text-xs font-bold uppercase tracking-widest text-slate-300 mb-1">Confirmar Nueva Contraseña</label>
                    <div class="relative">
                        <input type="password" id="confirm_password" name="confirm_password" required minlength="8" class="w-full bg-slate-900 border border-slate-700 rounded px-3 py-2 pr-10 text-sm text-white focus:outline-none focus:border-primary transition-all" placeholder="••••••••" onkeyup="checkPasswords()">
                        <button type="button" onclick="togglePassword('confirm_password', 'icon_confirm')" class="absolute inset-y-0 right-0 flex items-center pr-3 text-slate-400 hover:text-white transition-colors" title="Mostrar/Ocultar contraseña">
                            <span class="material-symbols-outlined text-[18px]" id="icon_confirm">visibility</span>
                        </button>
                    </div>
                    <p id="password_match_error" class="hidden text-red-500 text-xs font-bold mt-2 flex items-center gap-1">
                        <span class="material-symbols-outlined text-[14px]">error</span>
                        Las contraseñas no coinciden.
                    </p>
                </div>

                {# BOTONES #}
                <div class="flex gap-3 pt-2">
                    <a href="{{ path('profile_index') }}" class="flex-1 bg-slate-800 hover:bg-slate-700 text-white px-4 py-2 rounded transition-all font-bold uppercase text-sm text-center">
                        Cancelar
                    </a>
                    <button type="submit" id="btn_submit" class="flex-1 bg-primary hover:bg-primary/80 disabled:opacity-50 disabled:cursor-not-allowed text-white px-4 py-2 rounded transition-all font-bold uppercase text-sm">
                        ✓ Cambiar
                    </button>
                </div>

            </form>
        </div>
    </div>

    <script>
        // Cambiar entre tipo "password" y "text" y modificar el icono del ojo
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = 'visibility_off'; // Icono tachado
            } else {
                input.type = 'password';
                icon.textContent = 'visibility'; // Icono normal
            }
        }

        // Validar en tiempo real si la "Nueva" y "Confirmar" coinciden
        function checkPasswords() {
            const newPass = document.getElementById('new_password').value;
            const confirmPass = document.getElementById('confirm_password').value;
            const errorMsg = document.getElementById('password_match_error');
            const btnSubmit = document.getElementById('btn_submit');

            // Solo mostramos el error si ha empezado a escribir la confirmación
            if (confirmPass.length > 0 && newPass !== confirmPass) {
                errorMsg.classList.remove('hidden');
                btnSubmit.disabled = true; // Deshabilita el botón de enviar
            } else {
                errorMsg.classList.add('hidden');
                btnSubmit.disabled = false; // Vuelve a habilitar el botón
            }
        }
    </script>
{% endblock %}
