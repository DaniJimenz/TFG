{% extends 'base.html.twig' %}

{% block title %}Log in!{% endblock %}

{% block body %}
    <div class="flex h-screen w-full bg-background-dark text-white overflow-hidden">

        <div class="w-full lg:w-2/5 flex flex-col justify-center px-8 md:px-16 lg:px-24 bg-mesh relative z-10">

            <div class="mb-12 flex items-center gap-3">
                <h2 class="text-3xl font-bold tracking-tighter uppercase font-display">
                    <span class="text-white">META</span><span class="text-neon-blue">FIT</span>
                </h2>
            </div>

            <form method="post" class="space-y-6">
                {% if error %}
                    <div class="p-4 mb-4 text-sm text-red-400 bg-red-900/30 border border-red-800 rounded-xl">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <h1 class="text-white text-4xl font-bold tracking-tight mb-2">Tu transformación empieza aquí</h1>
                <p class="text-gray-400 text-lg mb-8">Accede a tu plataforma de alto rendimiento.</p>

                <div class="flex flex-col gap-2">
                    <label class="text-gray-300 text-sm font-medium ml-1">Email</label>
                    <input type="email" value="{{ last_username }}" name="_username" id="inputEmail" class="w-full rounded-xl bg-slate-900/50 border border-slate-800 text-white p-4 outline-none focus:border-primary transition-all placeholder:text-slate-600" placeholder="tu@email.com" required autofocus>
                </div>

                <div class="flex flex-col gap-2">
                    <label class="text-gray-300 text-sm font-medium ml-1">Contraseña</label>
                    <input type="password" name="_password" id="inputPassword" class="w-full rounded-xl bg-slate-900/50 border border-slate-800 text-white p-4 outline-none focus:border-primary transition-all placeholder:text-slate-600" placeholder="••••••••" required>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="pt-4">
                    <button class="w-full bg-primary hover:bg-blue-600 text-white font-bold py-5 rounded-xl transition-all glow-blue flex items-center justify-center gap-3" type="submit">
                        <span>Entrar al Sistema</span>
                        <span class="material-symbols-outlined text-xl">bolt</span>
                    </button>
                </div>

                {# AQUÍ ESTÁ EL NUEVO ENLACE DE REGISTRO #}
                <p class="mt-8 text-slate-500 text-center lg:text-left">
                    ¿Nuevo en el ecosistema?
                    <a class="text-primary font-bold hover:text-blue-400 transition-colors ml-1" href="{{ path('app_register') }}">
                        Crea tu cuenta
                    </a>
                </p>
            </form>
        </div>

        {# Imagen Derecha #}
        <div class="hidden lg:block lg:w-3/5 relative overflow-hidden bg-black">
            <div class="absolute inset-0 bg-gradient-to-r from-background-dark via-transparent to-transparent z-10 w-64"></div>
            <div class="w-full h-full bg-cover bg-center opacity-80" style="background-image: url('https://images.unsplash.com/photo-1534438327276-14e5300c3a48?q=80&w=2070&auto=format&fit=crop');"></div>
            <div class="absolute bottom-16 left-16 z-20 max-w-lg">
                <h3 class="text-5xl font-bold leading-tight text-white mb-4 italic">Redefine tus <span class="text-primary">límites</span>.</h3>
            </div>
        </div>
    </div>

{% endblock %}
