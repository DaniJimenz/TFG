{% extends 'base.html.twig' %}

{% block title %}Redes Sociales - MetaFit AI{% endblock %}

{% block body %}
    <div class="bg-background-dark text-white">
        <div class="max-w-4xl mx-auto pt-14 md:pt-16">

            <a href="{{ path('profile_index') }}" class="inline-flex items-center gap-2 text-slate-400 hover:text-white mb-8 transition-all">
                <span class="material-symbols-outlined text-xl">arrow_back</span>
                Volver al Perfil
            </a>

            <div class="mb-12">
                <div class="flex items-center gap-4 mb-4">
                    <div class="h-1 w-12 bg-primary"></div>
                    <span class="text-primary font-bold tracking-[0.3em] uppercase text-sm">Conexiones</span>
                </div>
                <h1 class="text-5xl font-black italic uppercase tracking-tighter">
                    Redes Sociales
                </h1>
            </div>

            {# PROVEEDORES DISPONIBLES #}
            <div class="bg-[#0d1117] border border-slate-800 rounded-2xl p-8 mb-8">
                <h3 class="text-2xl font-black uppercase mb-6">Conecta Tus Redes Sociales</h3>
                <p class="text-slate-400 mb-6">Conecta tus redes sociales para compartir automáticamente tus logros y estadísticas</p>

                <div class="grid md:grid-cols-2 gap-6">
                    {# GOOGLE #}
                    <div class="border border-slate-700 rounded-xl p-6 hover:border-primary transition-all">
                        <div class="flex items-center gap-3 mb-4">
                            <span class="text-4xl">🔵</span>
                            <h4 class="text-xl font-black">Google</h4>
                        </div>
                        <p class="text-sm text-slate-400 mb-4">Sincroniza con tu cuenta de Google y comparte logros</p>
                        <button type="button" class="w-full bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-bold uppercase transition-all">
                            🔗 Conectar con Google
                        </button>
                    </div>

                    {# FACEBOOK #}
                    <div class="border border-slate-700 rounded-xl p-6 hover:border-primary transition-all">
                        <div class="flex items-center gap-3 mb-4">
                            <span class="text-4xl">📘</span>
                            <h4 class="text-xl font-black">Facebook</h4>
                        </div>
                        <p class="text-sm text-slate-400 mb-4">Comparte tus entrenamientos con amigos en Facebook</p>
                        <button type="button" class="w-full bg-blue-800 hover:bg-blue-900 text-white px-4 py-2 rounded-lg font-bold uppercase transition-all">
                            🔗 Conectar con Facebook
                        </button>
                    </div>

                    {# INSTAGRAM #}
                    <div class="border border-slate-700 rounded-xl p-6 hover:border-primary transition-all">
                        <div class="flex items-center gap-3 mb-4">
                            <span class="text-4xl">📷</span>
                            <h4 class="text-xl font-black">Instagram</h4>
                        </div>
                        <p class="text-sm text-slate-400 mb-4">Comparte historias de tu progreso fitness</p>
                        <button type="button" class="w-full bg-pink-600 hover:bg-pink-700 text-white px-4 py-2 rounded-lg font-bold uppercase transition-all">
                            🔗 Conectar con Instagram
                        </button>
                    </div>

                    {# TWITTER #}
                    <div class="border border-slate-700 rounded-xl p-6 hover:border-primary transition-all">
                        <div class="flex items-center gap-3 mb-4">
                            <span class="text-4xl">𝕏</span>
                            <h4 class="text-xl font-black">Twitter/X</h4>
                        </div>
                        <p class="text-sm text-slate-400 mb-4">Publica tus hitos de entrenamiento</p>
                        <button type="button" class="w-full bg-gray-800 hover:bg-gray-900 text-white px-4 py-2 rounded-lg font-bold uppercase transition-all">
                            🔗 Conectar con X
                        </button>
                    </div>
                </div>
            </div>

            {# CONEXIONES ACTIVAS #}
            {% if connections|length > 0 %}
                <div class="bg-[#0d1117] border border-slate-800 rounded-2xl p-8">
                    <h3 class="text-2xl font-black uppercase mb-6">Tus Conexiones Activas</h3>
                    <div class="space-y-4">
                        {% for connection in connections %}
                            <div class="border border-slate-700 rounded-xl p-6 bg-slate-900/30">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-4">
                                        <span class="text-4xl">
                                            {% if connection.getProvider() == 'google' %}🔵
                                            {% elseif connection.getProvider() == 'facebook' %}📘
                                            {% elseif connection.getProvider() == 'instagram' %}📷
                                            {% elseif connection.getProvider() == 'twitter' %}𝕏
                                            {% endif %}
                                        </span>
                                        <div>
                                            <p class="font-black uppercase">{{ connection.getProvider()|capitalize }}</p>
                                            <p class="text-sm text-slate-400">{{ connection.getProviderEmail() ?? connection.getProviderName() }}</p>
                                            <p class="text-xs text-slate-500">Conectado: {{ connection.getConnectedAt()|date('d/m/Y') }}</p>
                                        </div>
                                    </div>
                                    <div class="flex gap-2">
                                        <label class="flex items-center gap-2 cursor-pointer">
                                            <input type="checkbox" {{ connection.isShareStats() ? 'checked' : '' }} class="w-4 h-4">
                                            <span class="text-xs">Compartir</span>
                                        </label>
                                        <form method="POST" class="inline">
                                            <input type="hidden" name="action" value="disconnect">
                                            <input type="hidden" name="connection_id" value="{{ connection.getId() }}">
                                            <button type="submit" class="bg-red-600 hover:bg-red-700 text-white px-3 py-1 rounded text-sm font-bold">
                                                Desconectar
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% else %}
                <div class="bg-slate-900/50 border border-slate-700 rounded-2xl p-8 text-center">
                    <p class="text-slate-400">No tienes conexiones activas. ¡Conecta una red social para compartir tus logros!</p>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
