{% extends 'base.html.twig' %}

{% block title %}Registrar Entrenamiento - MetaFit AI{% endblock %}

{% block body %}
<div class="bg-background-dark text-white">
    <div class="max-w-2xl mx-auto px-6 pt-6">

        {# HEADER #}
        <div class="mb-6">
            <div class="flex items-center gap-3 mb-2">
                <div class="h-1 w-10 bg-primary"></div>
                <span class="text-primary font-bold tracking-[0.3em] uppercase text-xs">Registrar Entrenamiento</span>
            </div>
            <h1 class="text-3xl font-black italic uppercase tracking-tighter">
                Nuevo <span class="text-primary">Entrenamiento</span>
            </h1>
        </div>

        {# FORM #}
        {{ form_start(form, {'attr': {'class': 'space-y-4', 'novalidate': 'novalidate'}}) }}

            {# EXERCISE #}
            <div>
                {{ form_label(form.exercise, 'Ejercicio', {'label_attr': {'class': 'block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1.5'}}) }}
                {{ form_widget(form.exercise, {'attr': {'class': 'w-full bg-slate-900 border border-slate-800 rounded-xl px-4 py-2.5 text-white text-sm focus:border-primary focus:outline-none transition'}}) }}
                {{ form_errors(form.exercise) }}
            </div>

            {# ROUTINE #}
            <div>
                {{ form_label(form.routine, 'Rutina (Opcional)', {'label_attr': {'class': 'block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1.5'}}) }}
                {{ form_widget(form.routine, {'attr': {'class': 'w-full bg-slate-900 border border-slate-800 rounded-xl px-4 py-2.5 text-white text-sm focus:border-primary focus:outline-none transition'}}) }}
            </div>

            {# SERIES + REPS + PESO #}
            <div class="grid grid-cols-3 gap-4">
                <div>
                    {{ form_label(form.completedSeries, 'Series', {'label_attr': {'class': 'block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1.5'}}) }}
                    {{ form_widget(form.completedSeries, {'attr': {'class': 'w-full bg-slate-900 border border-slate-800 rounded-xl px-4 py-2.5 text-white text-sm focus:border-primary focus:outline-none transition'}}) }}
                </div>
                <div>
                    {{ form_label(form.repetitions, 'Repeticiones', {'label_attr': {'class': 'block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1.5'}}) }}
                    {{ form_widget(form.repetitions, {'attr': {'class': 'w-full bg-slate-900 border border-slate-800 rounded-xl px-4 py-2.5 text-white text-sm focus:border-primary focus:outline-none transition'}}) }}
                </div>
                <div>
                    {{ form_label(form.weight, 'Peso (kg)', {'label_attr': {'class': 'block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1.5'}}) }}
                    {{ form_widget(form.weight, {'attr': {'class': 'w-full bg-slate-900 border border-slate-800 rounded-xl px-4 py-2.5 text-white text-sm focus:border-primary focus:outline-none transition'}}) }}
                </div>
            </div>

            {# 1RM ESTIMADO #}
            <div class="bg-slate-900 border border-slate-800 px-5 py-4 rounded-xl flex items-center justify-between">
                <div>
                    <p class="text-xs font-bold uppercase tracking-wider text-slate-400">1RM Estimado</p>
                    <p class="text-xs text-slate-600 mt-0.5">Fórmula de Epley: peso × (1 + reps/30)</p>
                </div>
                <div class="flex items-center gap-2">
                    <span id="oneRmValue" class="text-2xl font-black text-primary">—</span>
                    <span class="text-slate-500 text-sm font-bold">kg</span>
                </div>
            </div>

            {# NOTES #}
            <div>
                {{ form_label(form.notes, 'Notas', {'label_attr': {'class': 'block text-xs font-bold uppercase tracking-wider text-slate-400 mb-1.5'}}) }}
                {{ form_widget(form.notes, {'attr': {'class': 'w-full bg-slate-900 border border-slate-800 rounded-xl px-4 py-2.5 text-white text-sm focus:border-primary focus:outline-none transition', 'rows': '3'}}) }}
            </div>

            {# BUTTONS #}
            <div class="flex gap-4 pt-2">
                <button type="submit" class="flex-1 bg-primary hover:bg-primary/90 text-white px-6 py-3 rounded-xl transition-all font-bold text-sm uppercase">
                    Registrar Entrenamiento
                </button>
                <a href="{{ path('training_index') }}" class="flex-1 border border-slate-700 hover:bg-slate-800 text-slate-400 hover:text-white px-6 py-3 rounded-xl transition-all font-bold text-sm uppercase text-center">
                    Cancelar
                </a>
            </div>

        {{ form_end(form) }}

    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const repsInput = document.getElementById('training_form_type_repetitions');
        const weightInput = document.getElementById('training_form_type_weight');
        const oneRmDisplay = document.getElementById('oneRmValue');

        function calculateOneRM() {
            const reps = parseInt(repsInput?.value);
            const weight = parseFloat(weightInput?.value);

            if (reps > 0 && weight > 0) {
                const oneRM = weight * (1 + reps / 30);
                oneRmDisplay.textContent = oneRM.toFixed(1);
            } else {
                oneRmDisplay.textContent = '—';
            }
        }

        repsInput?.addEventListener('input', calculateOneRM);
        weightInput?.addEventListener('input', calculateOneRM);
    });
</script>
{% endblock %}
