{% extends 'base.html.twig' %}

{% block title %}Tus Logros - MetaFit AI{% endblock %}

{% block body %}
    <div class="bg-background-dark text-white min-h-screen pb-12">
        <div class="max-w-full mx-auto px-4 sm:px-6 pt-6 md:pt-8">
            
            {# CABECERA #}
            <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8">
                <div>
                    <h1 class="text-4xl md:text-5xl font-black italic uppercase tracking-tighter">
                        Tus <span class="text-primary">Logros</span>
                    </h1>
                    <p class="text-slate-400 mt-2 text-sm">
                        Desbloquea recompensas y gana experiencia completando retos.
                    </p>
                </div>
            </div>

            {# STATS GENERALES DE LOGROS #}
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 mb-10">
                <div class="bg-[#0d1117] border border-slate-800 p-4 rounded-xl">
                    <p class="text-slate-500 text-[9px] font-bold uppercase tracking-widest mb-2">Desbloqueados</p>
                    <p class="text-2xl font-black italic text-primary">{{ stats.unlocked }} <span class="text-xs text-slate-500 not-italic font-medium">/ {{ stats.total }}</span></p>
                </div>
                <div class="bg-[#0d1117] border border-slate-800 p-4 rounded-xl">
                    <p class="text-slate-500 text-[9px] font-bold uppercase tracking-widest mb-2">Completado</p>
                    <p class="text-2xl font-black italic text-white">{{ stats.percentage|number_format(0) }}<span class="text-xs text-primary ml-1">%</span></p>
                </div>
                <div class="bg-[#0d1117] border border-slate-800 p-4 rounded-xl col-span-2 md:col-span-2 flex items-center justify-between">
                    <div>
                        <p class="text-slate-500 text-[9px] font-bold uppercase tracking-widest mb-2">Total XP Ganada</p>
                        <p class="text-2xl font-black italic text-yellow-500">+{{ stats.totalXp }}</p>
                    </div>
                    <div class="text-yellow-500/20 text-4xl">
                        <span class="material-symbols-outlined text-5xl">military_tech</span>
                    </div>
                </div>
            </div>

            {# DESBLOQUEADOS #}
            <div class="mb-10">
                <h2 class="text-xl font-black italic uppercase tracking-tighter mb-4 text-white">Desbloqueados</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    {% for userAchiev in unlockedAchievements %}
                        <div class="bg-gradient-to-br from-primary/10 to-[#0d1117] border border-primary/30 p-5 rounded-2xl flex items-start gap-4 hover:border-primary/50 transition-all cursor-pointer">
                            <div class="w-12 h-12 min-w-12 bg-primary/20 rounded-xl flex items-center justify-center">
                                <span class="material-symbols-outlined text-primary text-2xl">emoji_events</span>
                            </div>
                            <div>
                                <h3 class="font-bold text-white text-sm mb-1 leading-tight">{{ userAchiev.achievement.name }}</h3>
                                <p class="text-xs text-slate-400 line-clamp-2 mb-3">{{ userAchiev.achievement.description }}</p>
                                <div class="flex items-center gap-2">
                                    <span class="text-[10px] font-black uppercase text-primary bg-primary/10 border border-primary/20 px-2 py-1 rounded-md">
                                        +{{ userAchiev.achievement.otorgatedXp }} XP
                                    </span>
                                    <span class="text-[10px] text-slate-500">{{ userAchiev.dateObtained|date('d/m/Y') }}</span>
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <div class="col-span-full p-8 text-center border border-dashed border-slate-800 rounded-2xl">
                            <p class="text-slate-500 text-sm">Aún no has desbloqueado ningún logro. ¡Sigue entrenando!</p>
                        </div>
                    {% endfor %}
                </div>
            </div>

            {# BLOQUEADOS #}
            <div>
                <h2 class="text-xl font-black italic uppercase tracking-tighter mb-4 text-slate-500">Por conseguir</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    {% for locked in lockedAchievements %}
                        <div class="bg-[#0d1117] border border-slate-800/50 p-5 rounded-2xl flex items-start gap-4 opacity-60 grayscale hover:grayscale-0 hover:opacity-100 transition-all cursor-default">
                            <div class="w-12 h-12 min-w-12 bg-slate-800 rounded-xl flex items-center justify-center">
                                <span class="material-symbols-outlined text-slate-500 text-2xl">lock</span>
                            </div>
                            <div>
                                <h3 class="font-bold text-slate-300 text-sm mb-1 leading-tight">{{ locked.name }}</h3>
                                <p class="text-xs text-slate-500 line-clamp-2 mb-3">{{ locked.description }}</p>
                                <span class="text-[10px] font-black uppercase text-slate-400 bg-slate-800 border border-slate-700 px-2 py-1 rounded-md">
                                    +{{ locked.otorgatedXp }} XP
                                </span>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>

        </div>
    </div>
{% endblock %}
