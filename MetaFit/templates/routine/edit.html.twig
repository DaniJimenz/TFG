{% extends 'base.html.twig' %}

{% block title %}Editar Rutina - MetaFit AI{% endblock %}

{% block body %}
    <div class="bg-background-dark text-white">
        <div class="max-w-6xl mx-auto pt-14 md:pt-16">

            {# HEADER #}
            <a href="{{ path('routine_index') }}" class="inline-flex items-center gap-2 text-slate-400 hover:text-white mb-8 transition-all">
                <span class="material-symbols-outlined text-xl">arrow_back</span>
                Volver a Rutinas
            </a>

            <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
                <div>
                    <div class="flex items-center gap-4 mb-4">
                        <div class="h-1 w-12 bg-primary"></div>
                        <span class="text-primary font-bold tracking-[0.3em] uppercase text-sm">Editar Rutina</span>
                    </div>
                    <h1 class="text-6xl font-black italic uppercase tracking-tighter mb-2">
                        {{ routine.getName() }}
                    </h1>
                    <p class="text-gray-400 text-lg font-light">{{ routine.getObjective() }}</p>
                </div>
                <a href="{{ path('routine_start', {id: routine.id}) }}" class="bg-primary hover:bg-primary/80 text-white px-6 py-3 rounded-xl transition-all font-bold text-xs uppercase">
                    Entrenar Ahora
                </a>
            </div>

            {# GRID #}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                {# EJERCICIOS EN LA RUTINA #}
                <div>
                    <h2 class="text-2xl font-black italic uppercase mb-6">Ejercicios en la Rutina</h2>
                    {% if exercises|length > 0 %}
                        <div class="space-y-3">
                            {% for exercise in exercises %}
                                <div class="bg-[#0d1117] border border-slate-800 rounded-xl p-4 flex items-center justify-between group hover:border-red-500/50 transition-all">
                                    <div class="flex-1">
                                        <p class="font-black italic text-white">{{ exercise.getName() }}</p>
                                        <p class="text-slate-500 text-xs">{{ exercise.getMuscularGroup() }} • {{ exercise.getDifficulty() }}</p>
                                    </div>
                                    <form method="POST" action="{{ path('routine_edit', {id: routine.id}) }}" class="ml-4">
                                        <input type="hidden" name="action" value="remove_exercise">
                                        <input type="hidden" name="exercise_id" value="{{ exercise.id }}">
                                        <button type="submit" class="text-red-500 hover:text-red-400 opacity-0 group-hover:opacity-100 transition-all">
                                            <span class="material-symbols-outlined">close</span>
                                        </button>
                                    </form>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="bg-slate-900/50 border border-dashed border-slate-700 rounded-xl p-8 text-center">
                            <p class="text-slate-500 italic">No hay ejercicios agregados aún</p>
                        </div>
                    {% endif %}
                </div>

                {# AGREGAR EJERCICIOS #}
                <div>
                    <h2 class="text-2xl font-black italic uppercase mb-6">Ejercicios Disponibles</h2>
                    {% if availableExercises|length > 0 %}
                        <div class="space-y-3 max-h-96 overflow-y-auto">
                            {% for exercise in availableExercises %}
                                <form method="POST" action="{{ path('routine_edit', {id: routine.id}) }}" class="bg-[#0d1117] border border-slate-800 rounded-xl p-4 flex items-center justify-between group hover:border-primary/50 transition-all">
                                    <input type="hidden" name="action" value="add_exercise">
                                    <input type="hidden" name="exercise_id" value="{{ exercise.id }}">
                                    <div class="flex-1">
                                        <p class="font-black italic text-white">{{ exercise.getName() }}</p>
                                        <p class="text-slate-500 text-xs">{{ exercise.getMuscularGroup() }} • {{ exercise.getDifficulty() }}</p>
                                    </div>
                                    <button type="submit" class="text-primary hover:text-primary/80 opacity-0 group-hover:opacity-100 transition-all ml-4">
                                        <span class="material-symbols-outlined">add_circle</span>
                                    </button>
                                </form>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="bg-slate-900/50 border border-dashed border-slate-700 rounded-xl p-8 text-center">
                            <p class="text-slate-500 italic">Todos los ejercicios están en la rutina</p>
                        </div>
                    {% endif %}
                </div>
            </div>

            {# INFORMACIÓN #}
            <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="bg-[#0d1117] border border-slate-800 p-6 rounded-2xl">
                    <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest mb-2">Días por Semana</p>
                    <p class="text-3xl font-black italic">{{ routine.getDaysWeek() }}</p>
                </div>
                <div class="bg-[#0d1117] border border-slate-800 p-6 rounded-2xl">
                    <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest mb-2">Material Disponible</p>
                    <p class="text-xl font-black italic">{{ routine.getDispoMaterial() }}</p>
                </div>
                <div class="bg-[#0d1117] border border-slate-800 p-6 rounded-2xl">
                    <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest mb-2">Total Ejercicios</p>
                    <p class="text-3xl font-black italic text-primary">{{ exercises|length }}</p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
