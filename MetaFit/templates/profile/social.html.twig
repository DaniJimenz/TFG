{% extends 'base.html.twig' %}

{% block title %}Redes Sociales - MetaFit AI{% endblock %}

{% block body %}
    <div class="bg-background-dark text-white min-h-screen flex flex-col">
        <div class="max-w-4xl mx-auto pt-8 md:pt-10 px-4 flex-1">

            <a href="{{ path('profile_index') }}" class="inline-flex items-center gap-2 text-slate-400 hover:text-white mb-8 transition-all">
                <span class="material-symbols-outlined text-xl">arrow_back</span>
                Volver al Perfil
            </a>

            <div class="mb-6">
                <div class="flex items-center gap-3 mb-2">
                    <div class="h-1 w-8 bg-primary"></div>
                    <span class="text-primary font-bold tracking-[0.2em] uppercase text-xs">Conexiones</span>
                </div>
                <h1 class="text-4xl md:text-5xl font-black italic uppercase tracking-tighter">
                    Redes Sociales
                </h1>
            </div>

            {# PROVEEDORES DISPONIBLES #}
            <div class="bg-[#0d1117] border border-slate-800 rounded-xl p-4 mb-4">
                <h3 class="text-lg font-black uppercase mb-3">Conecta tus Redes</h3>

                <div class="grid md:grid-cols-2 gap-3">
                    {# GOOGLE #}
                    <div class="border border-slate-700 rounded-lg p-3 hover:border-primary transition-all">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="text-3xl">🔵</span>
                            <h4 class="text-sm font-black">Google</h4>
                        </div>
                        <button type="button" class="w-full bg-blue-600 hover:bg-blue-700 text-white px-3 py-1.5 rounded text-sm font-bold uppercase transition-all">
                            🔗 Conectar
                        </button>
                    </div>

                    {# FACEBOOK #}
                    <div class="border border-slate-700 rounded-lg p-3 hover:border-primary transition-all">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="text-3xl">📘</span>
                            <h4 class="text-sm font-black">Facebook</h4>
                        </div>
                        <button type="button" class="w-full bg-blue-800 hover:bg-blue-900 text-white px-3 py-1.5 rounded text-sm font-bold uppercase transition-all">
                            🔗 Conectar
                        </button>
                    </div>

                    {# INSTAGRAM #}
                    <div class="border border-slate-700 rounded-lg p-3 hover:border-primary transition-all">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="text-3xl">📷</span>
                            <h4 class="text-sm font-black">Instagram</h4>
                        </div>
                        <button type="button" class="w-full bg-pink-600 hover:bg-pink-700 text-white px-3 py-1.5 rounded text-sm font-bold uppercase transition-all">
                            🔗 Conectar
                        </button>
                    </div>

                    {# TWITTER #}
                    <div class="border border-slate-700 rounded-lg p-3 hover:border-primary transition-all">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="text-3xl">𝕏</span>
                            <h4 class="text-sm font-black">Twitter/X</h4>
                        </div>
                        <button type="button" class="w-full bg-gray-800 hover:bg-gray-900 text-white px-3 py-1.5 rounded text-sm font-bold uppercase transition-all">
                            🔗 Conectar
                        </button>
                    </div>
                </div>
            </div>

            {# CONEXIONES ACTIVAS #}
            {% if connections|length > 0 %}
                <div class=\"bg-[#0d1117] border border-slate-800 rounded-xl p-4\">
                    <h3 class=\"text-lg font-black uppercase mb-3\">Activas</h3>
                    <div class=\"space-y-2\">
                        {% for connection in connections %}
                            <div class=\"border border-slate-700 rounded-lg p-2 bg-slate-900/30\">
                                <div class=\"flex items-center justify-between gap-2\">
                                    <div class=\"flex items-center gap-2 flex-1 min-w-0\">
                                        <span class=\"text-2xl flex-shrink-0\">
                                            {% if connection.getProvider() == 'google' %}🔵
                                            {% elseif connection.getProvider() == 'facebook' %}📘
                                            {% elseif connection.getProvider() == 'instagram' %}📷
                                            {% elseif connection.getProvider() == 'twitter' %}𝕏
                                            {% endif %}
                                        </span>
                                        <div class=\"min-w-0 flex-1\">
                                            <p class=\"font-black uppercase text-xs\">{{ connection.getProvider()|capitalize }}</p>
                                            <p class=\"text-xs text-slate-400 truncate\">{{ connection.getProviderEmail() ?? connection.getProviderName() }}</p>
                                        </div>
                                    </div>
                                    <form method=\"POST\" class=\"inline flex-shrink-0\">
                                        <input type=\"hidden\" name=\"action\" value=\"disconnect\">
                                        <input type=\"hidden\" name=\"connection_id\" value=\"{{ connection.getId() }}\">
                                        <button type=\"submit\" class=\"bg-red-600 hover:bg-red-700 text-white px-2 py-1 rounded text-xs font-bold\">
                                            X
                                        </button>
                                    </form>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% else %}
                <div class=\"bg-slate-900/50 border border-slate-700 rounded-lg p-3 text-center\">
                    <p class=\"text-slate-400 text-sm\">Sin conexiones activas. ¡Conecta una red social!</p>
                </div>
            {% endif %}

            {# BOTONES #}
            <div class=\"flex gap-3 pt-4\">
                <a href=\"{{ path('profile_index') }}\" class=\"flex-1 bg-slate-800 hover:bg-slate-700 text-white px-4 py-2 rounded transition-all font-bold uppercase text-sm text-center\">
                    Volver
                </a>
            </div>
        </div>
    </div>
{% endblock %}
