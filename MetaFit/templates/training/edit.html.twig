{% extends 'base.html.twig' %}

{% block title %}Editar Entrenamiento - MetaFit AI{% endblock %}

{% block body %}
<div class="bg-background-dark text-white">
    <div class="max-w-full mx-auto px-4 sm:px-6 pt-6 md:pt-8">

        {# HEADER #}
        <div class="mb-12">
            <div class="flex items-center gap-4 mb-4">
                <div class="h-1 w-12 bg-primary"></div>
                <span class="text-primary font-bold tracking-[0.3em] uppercase text-sm">Editar Entrenamiento</span>
            </div>
            <h1 class="text-4xl font-black italic uppercase tracking-tighter">
                Actualizar <span class="text-primary">{{ training.exercise.name }}</span>
            </h1>
            <p class="text-slate-400 mt-4">
                Registrado el {{ training.date|date('d/m/Y H:i') }}
            </p>
        </div>

        {# CURRENT STATS #}
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
            <div class="bg-[#0d1117] border border-slate-800 p-4 rounded-xl">
                <p class="text-slate-500 text-xs uppercase tracking-wider mb-1">Series</p>
                <p class="text-2xl font-bold">{{ training.completedSeries }}</p>
            </div>
            <div class="bg-[#0d1117] border border-slate-800 p-4 rounded-xl">
                <p class="text-slate-500 text-xs uppercase tracking-wider mb-1">Repeticiones</p>
                <p class="text-2xl font-bold">{{ training.repetitions }}</p>
            </div>
            <div class="bg-[#0d1117] border border-slate-800 p-4 rounded-xl">
                <p class="text-slate-500 text-xs uppercase tracking-wider mb-1">Peso</p>
                <p class="text-2xl font-bold text-accent-purple">{{ training.weight }} kg</p>
            </div>
            <div class="bg-[#0d1117] border border-slate-800 p-4 rounded-xl">
                <p class="text-slate-500 text-xs uppercase tracking-wider mb-1">1RM</p>
                <p class="text-2xl font-bold text-primary">{{ training.oneRmEstimated|number_format(1) }}</p>
            </div>
        </div>

        {# FORM #}
        <form method="POST" action="{{ form.vars.action }}" class="space-y-8">
            
            {# CSRF TOKEN #}
            {{ form_widget(form._token) }}

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                {# COMPLETED SERIES #}
                <div>
                    <label class="block text-sm font-bold uppercase tracking-wider text-slate-400 mb-3">
                        {{ form_label(form.completedSeries) }}
                    </label>
                    {{ form_widget(form.completedSeries, {
                        'attr': {
                            'class': 'w-full bg-slate-900 border border-slate-800 rounded-xl px-4 py-3 text-white focus:border-primary focus:outline-none transition',
                            'type': 'number',
                            'min': '1'
                        }
                    }) }}
                </div>

                {# REPETITIONS #}
                <div>
                    <label class="block text-sm font-bold uppercase tracking-wider text-slate-400 mb-3">
                        {{ form_label(form.repetitions) }}
                    </label>
                    {{ form_widget(form.repetitions, {
                        'attr': {
                            'class': 'w-full bg-slate-900 border border-slate-800 rounded-xl px-4 py-3 text-white focus:border-primary focus:outline-none transition',
                            'type': 'number',
                            'min': '1'
                        }
                    }) }}
                </div>

                {# WEIGHT #}
                <div>
                    <label class="block text-sm font-bold uppercase tracking-wider text-slate-400 mb-3">
                        {{ form_label(form.weight) }} <span class="text-slate-600">(kg)</span>
                    </label>
                    {{ form_widget(form.weight, {
                        'attr': {
                            'class': 'w-full bg-slate-900 border border-slate-800 rounded-xl px-4 py-3 text-white focus:border-primary focus:outline-none transition',
                            'type': 'number',
                            'step': '0.5',
                            'min': '0'
                        }
                    }) }}
                </div>

                {# DURATION #}
                <div>
                    <label class="block text-sm font-bold uppercase tracking-wider text-slate-400 mb-3">
                        {{ form_label(form.durationMinutes) }} <span class="text-slate-600">(min)</span>
                    </label>
                    {{ form_widget(form.durationMinutes, {
                        'attr': {
                            'class': 'w-full bg-slate-900 border border-slate-800 rounded-xl px-4 py-3 text-white focus:border-primary focus:outline-none transition',
                            'type': 'number',
                            'min': '1'
                        }
                    }) }}
                </div>
            </div>

            {# 1RM ESTIMATED #}
            <div class="bg-slate-900 border border-slate-800 p-6 rounded-xl">
                <p class="text-sm font-bold uppercase tracking-wider text-slate-400 mb-3">1RM Estimado (Actualizado)</p>
                <div class="flex items-center gap-4">
                    <input type="number" id="oneRmEstimated" step="0.1" class="flex-1 bg-slate-800 border border-slate-700 rounded-lg px-4 py-2 text-white focus:border-primary focus:outline-none transition" disabled>
                    <span class="text-slate-600">kg</span>
                </div>
                <p class="text-xs text-slate-500 mt-3">Se recalculará automáticamente con tus cambios</p>
            </div>

            {# COMPLETED #}
            <div class="flex items-center gap-4">
                <input type="checkbox" id="training_form_completed" name="training_form[completed]" value="1" {% if training.completed %}checked{% endif %} class="w-5 h-5 bg-slate-900 border border-slate-800 rounded cursor-pointer">
                <label for="training_form_completed" class="text-sm font-bold uppercase tracking-wider text-slate-400 cursor-pointer">
                    {{ form_label(form.completed) }}
                </label>
            </div>

            {# NOTES #}
            <div>
                <label class="block text-sm font-bold uppercase tracking-wider text-slate-400 mb-3">
                    {{ form_label(form.notes) }}
                </label>
                {{ form_widget(form.notes, {
                    'attr': {
                        'class': 'w-full bg-slate-900 border border-slate-800 rounded-xl px-4 py-3 text-white focus:border-primary focus:outline-none transition',
                        'rows': '4',
                        'placeholder': 'Notas sobre el entrenamiento...'
                    }
                }) }}
            </div>

            {# BUTTONS #}
            <div class="flex gap-4 pt-6">
                <button type="submit" class="flex-1 bg-primary hover:bg-primary/90 text-white px-6 py-3 rounded-xl transition-all font-bold text-sm uppercase">
                    Guardar Cambios
                </button>
                <a href="{{ path('training_show', {'id': training.id}) }}" class="flex-1 border border-slate-700 hover:bg-slate-800 text-slate-400 hover:text-white px-6 py-3 rounded-xl transition-all font-bold text-sm uppercase text-center">
                    Cancelar
                </a>
            </div>
        </form>

    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const completedSeriesInput = document.querySelector('input[name="training_form[completedSeries]"]');
        const repetitionsInput = document.querySelector('input[name="training_form[repetitions]"]');
        const weightInput = document.querySelector('input[name="training_form[weight]"]');
        const oneRmInput = document.getElementById('oneRmEstimated');

        function calculateOneRM() {
            const series = parseInt(completedSeriesInput?.value || 0);
            const reps = parseInt(repetitionsInput?.value || 0);
            const weight = parseFloat(weightInput?.value || 0);

            if (weight > 0 && reps > 0) {
                // Epley formula: weight × (1 + reps/30)
                const oneRM = weight * (1 + (reps / 30));
                oneRmInput.value = oneRM.toFixed(1);
            } else {
                oneRmInput.value = '';
            }
        }

        completedSeriesInput?.addEventListener('change', calculateOneRM);
        repetitionsInput?.addEventListener('change', calculateOneRM);
        repetitionsInput?.addEventListener('input', calculateOneRM);
        weightInput?.addEventListener('change', calculateOneRM);
        weightInput?.addEventListener('input', calculateOneRM);

        // Initial calculation
        calculateOneRM();
    });
</script>
{% endblock %}
