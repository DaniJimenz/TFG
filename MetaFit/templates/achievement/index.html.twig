{% extends 'base.html.twig' %}

{% block title %}Logros y Experiencia - MetaFit{% endblock %}

{% block body %}
    <div class="bg-primary text-text-main">
        <div class="max-w-7xl mx-auto pt-14 md:pt-16">

            {# HEADER #}
            <div class="mb-12">
                <div class="flex items-center gap-4 mb-4">
                    <div class="h-1 w-12 bg-accent"></div>
                    <span class="text-accent font-bold tracking-[0.3em] uppercase text-sm">Sistema de Logros</span>
                </div>
                <h1 class="text-6xl font-black italic uppercase tracking-tighter mb-2">
                    Tus <span class="text-accent">Logros</span>
                </h1>
                <p class="text-text-muted text-xl font-light">
                    Desbloquea logros completando entrenamientos y alcanzando metas
                </p>
            </div>

            {# ESTADÍSTICAS #}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-12">
                <div class="bg-card border border-card p-6 rounded-2xl">
                    <p class="text-text-muted text-[10px] font-bold uppercase tracking-widest mb-2">Total Desbloqueados</p>
                    <p class="text-4xl font-black italic text-accent">{{ stats.unlocked }}<span class="text-text-muted text-lg ml-2">/ {{ stats.total }}</span></p>
                </div>
                <div class="bg-card border border-card p-6 rounded-2xl">
                    <p class="text-text-muted text-[10px] font-bold uppercase tracking-widest mb-2">Progreso</p>
                    <div class="flex items-baseline gap-2">
                        <p class="text-4xl font-black italic">{{ stats.percentage|number_format(0) }}%</p>
                    </div>
                    <div class="w-full bg-card h-2 rounded-full mt-3 overflow-hidden border border-accent/20">
                        <div class="bg-accent h-full transition-all" style="width: {{ stats.percentage }}%"></div>
                    </div>
                </div>
                <div class="bg-accent p-6 rounded-2xl">
                    <p class="text-primary/80 text-[10px] font-bold uppercase tracking-widest mb-2">XP Total Ganado</p>
                    <p class="text-4xl font-black italic text-primary">{{ stats.totalXp }}</p>
                </div>
                <div class="bg-card border border-card p-6 rounded-2xl">
                    <p class="text-text-muted text-[10px] font-bold uppercase tracking-widest mb-2">Por Desbloquear</p>
                    <p class="text-4xl font-black italic text-text-muted">{{ stats.locked }}</p>
                </div>
            </div>

            {# LOGROS DESBLOQUEADOS #}
            {% if unlockedAchievements|length > 0 %}
                <div class="mb-12">
                    <h2 class="text-3xl font-black italic uppercase tracking-tighter mb-8">
                        <span class="material-symbols-outlined inline-block align-middle mr-3 text-accent text-3xl">check_circle</span>
                        Logros Desbloqueados
                    </h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                        {% for userAchievement in unlockedAchievements %}
                            {% set achievement = userAchievement.getAchievement() %}
                            <a href="{{ path('achievement_show', {id: achievement.id}) }}" class="group bg-gradient-to-br from-accent/20 to-transparent border border-accent/50 rounded-2xl p-6 hover:border-accent hover:from-accent/30 transition-all">
                                <div class="flex items-start justify-between mb-4">
                                    <div class="w-12 h-12 bg-accent/30 rounded-xl flex items-center justify-center text-xl group-hover:bg-accent/50 transition-all">
                                        <span class="material-symbols-outlined text-accent">{{ achievement.getUrlIcon() }}</span>
                                    </div>
                                    <div class="text-right">
                                        <p class="text-accent font-black text-lg">+{{ achievement.getOtorgatedXp() }} XP</p>
                                        <p class="text-text-muted text-xs">{{ userAchievement.getDateObtained()|date('d/m/Y') }}</p>
                                    </div>
                                </div>
                                <h3 class="text-xl font-black italic uppercase text-text-main mb-2 group-hover:text-accent transition-all">
                                    {{ achievement.getName() }}
                                </h3>
                                <p class="text-text-muted text-sm line-clamp-2">
                                    {{ achievement.getDescription() }}
                                </p>
                                <div class="mt-4 pt-4 border-t border-accent/20 flex justify-between items-center text-[10px] font-black uppercase tracking-tighter text-text-muted">
                                    <span>{{ achievement.getType()|upper }}</span>
                                    <span class="text-accent">DESBLOQUEADO</span>
                                </div>
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# LOGROS POR DESBLOQUEAR #}
            {% if lockedAchievements|length > 0 %}
                <div>
                    <h2 class="text-3xl font-black italic uppercase tracking-tighter mb-8">
                        <span class="material-symbols-outlined inline-block align-middle mr-3 text-text-muted text-3xl">lock</span>
                        Logros por Desbloquear
                    </h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                        {% for achievement in lockedAchievements %}
                            <a href="{{ path('achievement_show', {id: achievement.id}) }}" class="group bg-card border border-card rounded-2xl p-6 hover:border-text-muted transition-all opacity-60 hover:opacity-100">
                                <div class="flex items-start justify-between mb-4">
                                    <div class="w-12 h-12 bg-card/50 rounded-xl flex items-center justify-center text-xl group-hover:bg-card/80 transition-all">
                                        <span class="material-symbols-outlined text-text-muted">{{ achievement.getUrlIcon() }}</span>
                                    </div>
                                    <div class="text-right">
                                        <p class="text-text-muted font-black text-lg">+{{ achievement.getOtorgatedXp() }} XP</p>
                                        <p class="text-text-muted/50 text-xs">BLOQUEADO</p>
                                    </div>
                                </div>
                                <h3 class="text-xl font-black italic uppercase text-text-muted mb-2">
                                    {{ achievement.getName() }}
                                </h3>
                                <p class="text-text-muted/70 text-sm line-clamp-2">
                                    {{ achievement.getDescription() }}
                                </p>
                                <div class="mt-4 pt-4 border-t border-card flex justify-between items-center text-[10px] font-black uppercase tracking-tighter text-text-muted/50">
                                    <span>{{ achievement.getType()|upper }}</span>
                                    <span>POR DESBLOQUEAR</span>
                                </div>
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {# SIN LOGROS #}
            {% if unlockedAchievements|length == 0 and lockedAchievements|length == 0 %}
                <div class="py-20 text-center border-2 border-dashed border-card rounded-3xl">
                    <span class="material-symbols-outlined block text-5xl text-text-muted mb-4 mx-auto">info</span>
                    <p class="text-text-muted text-xl italic mb-4">No hay logros disponibles</p>
                    <a href="{{ path('app_library_index') }}" class="text-accent hover:underline font-bold">
                        Ir a la Biblioteca de Ejercicios →
                    </a>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
