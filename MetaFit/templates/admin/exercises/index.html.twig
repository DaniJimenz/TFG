{% extends 'base.html.twig' %}

{% block title %}Administrador de Ejercicios - MetaFit AI{% endblock %}

{% block body %}
<div class="bg-primary text-text-main">
    <div class="max-w-7xl mx-auto pt-14 md:pt-16">

        {# HEADER #}
        <div class="mb-12">
            <div class="flex items-center justify-between">
                <div>
                    <div class="flex items-center gap-4 mb-4">
                        <div class="h-1 w-12 bg-accent"></div>
                        <span class="text-accent font-bold tracking-[0.3em] uppercase text-sm">Administración</span>
                    </div>
                    <h1 class="text-4xl font-black italic uppercase tracking-tighter">
                        Editar <span class="text-accent">Ejercicios</span>
                    </h1>
                </div>
                <a href="{{ path('app_library_index') }}" class="text-text-muted hover:text-text-main transition-colors">
                    <span class="material-symbols-outlined text-3xl">arrow_back</span>
                </a>
            </div>
        </div>

        {# TABLA DE EJERCICIOS #}
        <div class="overflow-x-auto rounded-2xl border border-card bg-card/50">
            <table class="w-full">
                <thead>
                    <tr class="bg-card border-b border-card/50">
                        <th class="px-6 py-4 text-left text-sm font-bold text-text-muted uppercase">Ejercicio</th>
                        <th class="px-6 py-4 text-left text-sm font-bold text-text-muted uppercase">Grupo</th>
                        <th class="px-6 py-4 text-left text-sm font-bold text-text-muted uppercase">Imagen</th>
                        <th class="px-6 py-4 text-left text-sm font-bold text-text-muted uppercase">Video</th>
                        <th class="px-6 py-4 text-left text-sm font-bold text-text-muted uppercase">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {% for exercise in exercises %}
                    <tr class="border-b border-card/30 hover:bg-card transition-colors">
                        <td class="px-6 py-4">
                            <span class="font-bold text-text-main">{{ exercise.name }}</span>
                        </td>
                        <td class="px-6 py-4">
                            <span class="text-xs bg-accent/10 text-accent px-3 py-1 rounded-full font-bold">{{ exercise.muscularGroup }}</span>
                        </td>
                        <td class="px-6 py-4">
                            {% if exercise.urlImage %}
                                <div class="w-12 h-12 rounded-lg overflow-hidden border border-card bg-card/50">
                                    <img src="{{ exercise.urlImage }}" alt="{{ exercise.name }}" class="w-full h-full object-cover">
                                </div>
                            {% else %}
                                <span class="text-text-muted text-xs">Sin imagen</span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-4">
                            {% if exercise.urlVideo %}
                                <span class="text-xs text-green-400 font-bold">✓ Sí</span>
                            {% else %}
                                <span class="text-xs text-error font-bold">✗ No</span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-4">
                            <a href="{{ path('admin_exercises_quick_edit', {'id': exercise.id}) }}" class="inline-block bg-accent hover:bg-accent/90 text-black px-4 py-2 rounded-lg text-xs font-bold uppercase transition-all">
                                Editar
                            </a>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="mt-8 p-6 bg-card border border-card/50 rounded-xl">
            <p class="text-text-muted text-sm">
                <strong class="text-text-main">Total:</strong> {{ exercises|length }} ejercicios
            </p>
        </div>

    </div>
</div>
{% endblock %}
