{% extends 'base.html.twig' %}

{% block title %}Comienza tu viaje - MetaFit AI{% endblock %}

{% block body %}
    <div class="bg-background-dark min-h-screen flex items-center justify-center p-4">
        {# TARJETA PRINCIPAL #}
        <div class="bg-[#0d1117] border border-slate-800 rounded-3xl p-6 sm:p-8 max-w-lg w-full shadow-2xl relative overflow-hidden">
            
            {# Decoración sutil de fondo #}
            <div class="absolute top-0 right-0 w-32 h-32 bg-primary/10 rounded-full blur-3xl -mr-10 -mt-10 pointer-events-none"></div>

            {# Mostrar Errores de Validación de Symfony #}
            {% for message in app.flashes('error') %}
                <div class="bg-red-500/10 border border-red-500/30 text-red-400 rounded-xl p-3 mb-6 relative z-10 text-sm font-bold flex items-center gap-2">
                    <span class="material-symbols-outlined text-lg">error</span>
                    {{ message }}
                </div>
            {% endfor %}

            <div class="text-center mb-8 relative z-10">
                <h1 class="text-3xl sm:text-4xl font-black italic uppercase tracking-tighter text-white mb-2">
                    Completa tu <span class="text-primary">Perfil</span>
                </h1>
                <p class="text-slate-400 text-sm">
                    La IA necesita estos datos para generar tu primera rutina y calcular tus macros.
                </p>
            </div>

            <form method="POST" action="{{ path('app_onboarding') }}" class="space-y-4 relative z-10">
                
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Edad</label>
                        <input type="number" name="age" required class="w-full bg-slate-900 border border-slate-700 text-white text-sm rounded-xl p-3 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all">
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Sexo</label>
                        <select name="gender" required class="w-full bg-slate-900 border border-slate-700 text-white text-sm rounded-xl p-3 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all">
                            <option value="H">Hombre</option>
                            <option value="M">Mujer</option>
                        </select>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Altura (cm)</label>
                        <input type="number" step="0.1" name="height" required class="w-full bg-slate-900 border border-slate-700 text-white text-sm rounded-xl p-3 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all">
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Peso (kg)</label>
                        <input type="number" step="0.1" name="weight" required class="w-full bg-slate-900 border border-slate-700 text-white text-sm rounded-xl p-3 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all">
                    </div>
                </div>

                <div>
                    <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Nivel de Actividad</label>
                    <select name="activity_level" required class="w-full bg-slate-900 border border-slate-700 text-white text-sm rounded-xl p-3 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all">
                        <option value="Baja">Baja (Sedentario)</option>
                        <option value="Media">Media (1-3 días/semana)</option>
                        <option value="Alta">Alta (4-5 días/semana)</option>
                    </select>
                </div>

                <div>
                    <label class="block text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Objetivo Principal</label>
                    <select name="purpose" required class="w-full bg-slate-900 border border-slate-700 text-white text-sm rounded-xl p-3 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all">
                        <option value="Perder grasa">Perder grasa</option>
                        <option value="Mantenimiento">Mantenimiento general</option>
                        <option value="Ganar masa muscular">Ganar masa muscular</option>
                    </select>
                </div>

                <button type="submit" class="w-full mt-6 bg-primary hover:bg-primary/90 text-white font-bold text-sm uppercase py-4 rounded-xl transition-all flex justify-center items-center gap-2">
                    Generar mi plan
                    <span class="material-symbols-outlined text-lg">arrow_forward</span>
                </button>
            </form>
        </div>
    </div>
{% endblock %}
