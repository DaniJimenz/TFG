{% extends 'base.html.twig' %}

{% block title %}Privacidad - MetaFit AI{% endblock %}

{% block body %}
    <div class="bg-background-dark text-white min-h-screen flex flex-col">
        <div class="max-w-full mx-auto pt-6 md:pt-8 px-4 flex-1">

            <a href="{{ path('profile_index') }}" class="inline-flex items-center gap-2 text-slate-400 hover:text-white mb-8 transition-all">
                <span class="material-symbols-outlined text-xl">arrow_back</span>
                Volver al Perfil
            </a>

            <div class="mb-6">
                <div class="flex items-center gap-3 mb-2">
                    <div class="h-1 w-8 bg-primary"></div>
                    <span class="text-primary font-bold tracking-[0.2em] uppercase text-xs">Seguridad</span>
                </div>
                <h1 class="text-4xl md:text-5xl font-black italic uppercase tracking-tighter">
                    Privacidad
                </h1>
            </div>

            <form method="POST" class="space-y-4">

                {# VISIBILIDAD DEL PERFIL #}
                <div class="bg-[#0d1117] border border-slate-800 rounded-xl p-4">
                    <h3 class="text-lg font-black uppercase mb-3">Visibilidad</h3>
                    <div class="space-y-2">
                        <label class="flex items-start gap-2 p-2">
                            <input type="checkbox" name="profile_public" {{ preferences and preferences.isProfilePublic() ? 'checked' : '' }} class="w-4 h-4 mt-0.5">
                            <div>
                                <p class="font-bold text-sm">Perfil Público</p>
                                <p class="text-xs text-slate-400">Otros usuarios pueden ver tu perfil y estadísticas</p>
                            </div>
                        </label>

                        <label class="flex items-start gap-2 p-2">
                            <input type="checkbox" name="stats_visible" {{ preferences and preferences.isStatsVisible() ? 'checked' : '' }} class="w-4 h-4 mt-0.5">
                            <div>
                                <p class="font-bold text-sm">Mostrar Estadísticas</p>
                                <p class="text-xs text-slate-400">Permite que otros vean tus entrenamientos</p>
                            </div>
                        </label>

                        <label class="flex items-start gap-2 p-2">
                            <input type="checkbox" name="achievements_visible" {{ preferences and preferences.isAchievementsVisible() ? 'checked' : '' }} class="w-4 h-4 mt-0.5">
                            <div>
                                <p class="font-bold text-sm">Mostrar Logros</p>
                                <p class="text-xs text-slate-400">Otros pueden ver tus logros desbloqueados</p>
                            </div>
                        </label>

                        <label class="flex items-start gap-2 p-2">
                            <input type="checkbox" name="routines_visible" {{ preferences and preferences.isRoutinesVisible() ? 'checked' : '' }} class="w-4 h-4 mt-0.5">
                            <div>
                                <p class="font-bold text-sm">Compartir Rutinas</p>
                                <p class="text-xs text-slate-400">Otros pueden ver y copiar tus rutinas</p>
                            </div>
                        </label>
                    </div>
                </div>

                {# INFORMACIÓN DE SEGURIDAD #}
                <div class="bg-gradient-to-r from-orange-500/10 to-transparent border border-orange-500/30 rounded-xl p-4">
                    <div class="flex gap-3">
                        <span class="material-symbols-outlined text-xl text-orange-400 flex-shrink-0">info</span>
                        <div>
                            <h3 class="font-black uppercase text-sm mb-1">Seguridad</h3>
                            <ul class="text-xs text-slate-300 space-y-1">
                                <li>• Tu información nunca será vendida a terceros</li>
                                <li>• Puedes cambiar configuraciones en cualquier momento</li>
                                <li>• Tus datos están encriptados</li>
                            </ul>
                        </div>
                    </div>
                </div>

                {# BOTONES #}
                <div class="flex gap-3 pt-4">
                    <a href="{{ path('profile_index') }}" class="flex-1 bg-slate-800 hover:bg-slate-700 text-white px-4 py-2 rounded transition-all font-bold uppercase text-sm text-center">
                        Cancelar
                    </a>
                    <button type="submit" class="flex-1 bg-primary hover:bg-primary/80 text-white px-4 py-2 rounded transition-all font-bold uppercase text-sm">
                        ✓ Guardar
                    </button>
                </div>

            </form>
        </div>
    </div>
