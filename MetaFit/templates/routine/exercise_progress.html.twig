{% extends 'base.html.twig' %}

{% block title %}Progreso · {{ exercise.getName() }} — MetaFit AI{% endblock %}

{% block body %}
<div class="bg-background-dark text-white">
    <div class="max-w-full mx-auto px-4 sm:px-6 pt-6 md:pt-8">

        {# BACK #}
        <a href="javascript:history.back()" class="inline-flex items-center gap-2 text-slate-500 hover:text-white mb-8 transition-all text-sm font-bold uppercase tracking-wider">
            <span class="material-symbols-outlined text-base">arrow_back</span>
            Volver
        </a>

        {# HEADER #}
        <div class="mb-10">
            <div class="flex items-center gap-4 mb-3">
                <div class="h-1 w-12 bg-primary"></div>
                <span class="text-primary font-bold tracking-[0.3em] uppercase text-sm">Progreso por Ejercicio</span>
            </div>
            <h1 class="text-5xl md:text-6xl font-black italic uppercase tracking-tighter mb-3">
                {{ exercise.getName() }}
            </h1>
            <div class="flex gap-3 flex-wrap">
                <span class="bg-primary/10 text-primary text-xs font-black px-3 py-1 rounded-lg border border-primary/20">{{ exercise.getMuscularGroup() }}</span>
                {% if exercise.getNecessaryMaterial() %}
                    <span class="bg-slate-800 text-slate-400 text-xs font-black px-3 py-1 rounded-lg border border-slate-700">{{ exercise.getNecessaryMaterial() }}</span>
                {% endif %}
                <span class="bg-slate-800 text-slate-400 text-xs font-black px-3 py-1 rounded-lg border border-slate-700">{{ exercise.getDifficulty()|default('—') }}</span>
            </div>
        </div>

        {% if totalTrainings == 0 %}
            <div class="py-24 text-center border-2 border-dashed border-slate-800 rounded-3xl">
                <span class="material-symbols-outlined text-6xl text-slate-700 mb-4 block">monitoring</span>
                <p class="text-slate-400 text-xl font-bold italic uppercase mb-2">Sin datos aún</p>
                <p class="text-slate-600 text-sm">Completa al menos una sesión con este ejercicio para ver tu progreso.</p>
            </div>

        {% else %}

        {# STATS — datos con sentido por ejercicio #}
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">

            {# Última sesión #}
            <div class="bg-[#0d1117] border border-slate-800 rounded-2xl p-5">
                <div class="flex items-center gap-2 mb-3">
                    <span class="material-symbols-outlined text-primary text-lg">today</span>
                    <p class="text-slate-400 text-xs uppercase font-bold tracking-wider">Última sesión</p>
                </div>
                <p class="text-3xl font-black text-white">{{ lastWeight|round(1) }} <span class="text-base font-bold text-slate-500">kg</span></p>
                <p class="text-xs text-slate-600 mt-1">{{ lastSeries }}×{{ lastReps }} · {{ lastTraining.date|date('d/m/Y') }}</p>
            </div>

            {# Récord personal #}
            <div class="bg-[#0d1117] border border-slate-800 rounded-2xl p-5">
                <div class="flex items-center gap-2 mb-3">
                    <span class="material-symbols-outlined text-yellow-400 text-lg">emoji_events</span>
                    <p class="text-slate-400 text-xs uppercase font-bold tracking-wider">Récord (PR)</p>
                </div>
                <p class="text-3xl font-black text-yellow-400">{{ prWeight|round(1) }} <span class="text-base font-bold text-slate-500">kg</span></p>
                <p class="text-xs text-slate-600 mt-1">Máximo histórico</p>
            </div>

            {# 1RM estimado #}
            <div class="bg-[#0d1117] border border-slate-800 rounded-2xl p-5">
                <div class="flex items-center gap-2 mb-3">
                    <span class="material-symbols-outlined text-purple-400 text-lg">psychology</span>
                    <p class="text-slate-400 text-xs uppercase font-bold tracking-wider">Mejor 1RM</p>
                </div>
                <p class="text-3xl font-black text-purple-400">{{ bestOneRM|round(1) }} <span class="text-base font-bold text-slate-500">kg</span></p>
                <p class="text-xs text-slate-600 mt-1">Fórmula de Brzycki</p>
            </div>

            {# Progreso total #}
            <div class="bg-[#0d1117] border border-slate-800 rounded-2xl p-5">
                <div class="flex items-center gap-2 mb-3">
                    <span class="material-symbols-outlined {{ weightGain >= 0 ? 'text-emerald-400' : 'text-red-400' }} text-lg">trending_up</span>
                    <p class="text-slate-400 text-xs uppercase font-bold tracking-wider">Progreso total</p>
                </div>
                <p class="text-3xl font-black {{ weightGain >= 0 ? 'text-emerald-400' : 'text-red-400' }}">
                    {{ weightGain >= 0 ? '+' : '' }}{{ weightGain|round(1) }} <span class="text-base font-bold text-slate-500">kg</span>
                </p>
                <p class="text-xs text-slate-600 mt-1">{{ firstWeight|round(1) }} → {{ lastWeight|round(1) }} kg · {{ totalTrainings }} sesiones</p>
            </div>

        </div>

        {# RECOMENDACIÓN + HISTORIAL #}
        <div class="grid lg:grid-cols-[360px_1fr] gap-6 mb-10 items-start">

            <div class="bg-[#0d1117] border border-primary/30 rounded-2xl p-6 flex flex-col gap-5">
                <div class="flex items-center gap-3">
                    <div class="h-1 w-8 bg-primary"></div>
                    <h3 class="text-sm font-black uppercase tracking-widest text-slate-300">Próxima sesión</h3>
                </div>

                {# Resumen última sesión #}
                <div class="bg-slate-900/60 rounded-xl p-4">
                    <p class="text-xs text-slate-500 uppercase font-bold mb-3">Última vez hiciste</p>
                    <div class="flex items-end gap-2 mb-1">
                        <span class="text-3xl font-black text-white">{{ lastSeries }}×{{ lastReps }}</span>
                        <span class="text-slate-500 text-sm font-bold mb-1">reps</span>
                    </div>
                    <p class="text-primary font-black text-lg">a {{ lastWeight|round(1) }} kg</p>
                    <p class="text-xs text-slate-600 mt-1">{{ lastTraining.date|date('d/m/Y') }}</p>
                </div>

                {# Recomendación #}
                {% if nextLoad > 0 %}
                <div class="bg-primary/5 border border-primary/20 rounded-xl p-4">
                    <p class="text-xs text-slate-500 uppercase font-bold mb-2">Te recomendamos subir a</p>
                    <p class="text-4xl font-black text-primary">{{ nextLoad }} <span class="text-lg text-slate-500 font-bold">kg</span></p>
                    <div class="flex gap-4 mt-3 text-xs">
                        <span class="text-slate-500">Aumento: <span class="text-primary font-bold">+{{ (nextLoad - lastWeight)|round(1) }} kg</span></span>
                        <span class="text-slate-500">({{ ((nextLoad / lastWeight - 1) * 100)|round(1) }}%)</span>
                    </div>
                </div>
                {% endif %}

                <div class="space-y-2">
                    <p class="text-xs text-slate-600 uppercase font-bold">Recuerda</p>
                    <div class="flex items-start gap-2 text-xs text-slate-500">
                        <span class="material-symbols-outlined text-primary text-sm mt-0.5">check_circle</span>
                        Solo sube peso si completaste todas las series
                    </div>
                    <div class="flex items-start gap-2 text-xs text-slate-500">
                        <span class="material-symbols-outlined text-primary text-sm mt-0.5">check_circle</span>
                        Prioriza la técnica sobre el peso
                    </div>
                </div>
            </div>

            {# HISTORIAL #}
            <div class="bg-[#0d1117] border border-slate-800 rounded-2xl overflow-hidden">
            <div class="px-6 py-5 border-b border-slate-800 flex items-center gap-3">
                <div class="h-1 w-8 bg-primary"></div>
                <h3 class="text-sm font-black uppercase tracking-widest text-slate-300">Historial de sesiones</h3>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-slate-800">
                            <th class="px-6 py-3 text-left text-xs font-black uppercase tracking-wider text-slate-500">Fecha</th>
                            <th class="px-6 py-3 text-right text-xs font-black uppercase tracking-wider text-slate-500">Series</th>
                            <th class="px-6 py-3 text-right text-xs font-black uppercase tracking-wider text-slate-500">Reps</th>
                            <th class="px-6 py-3 text-right text-xs font-black uppercase tracking-wider text-slate-500">Peso</th>
                            <th class="px-6 py-3 text-right text-xs font-black uppercase tracking-wider text-slate-500">Volumen sesión</th>
                            <th class="px-6 py-3 text-right text-xs font-black uppercase tracking-wider text-slate-500">1RM Est.</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for training in trainings %}
                            <tr class="border-b border-slate-800/50 hover:bg-slate-900/40 transition-all {{ loop.first ? 'bg-primary/5' : '' }}">
                                <td class="px-6 py-4 text-sm text-slate-400">
                                    {{ training.date|date('d/m/Y') }}
                                    {% if loop.first %}<span class="ml-2 text-[10px] bg-primary/20 text-primary px-2 py-0.5 rounded font-black uppercase">Última</span>{% endif %}
                                </td>
                                <td class="px-6 py-4 text-right text-sm text-slate-300 font-bold">{{ training.completedSeries }}</td>
                                <td class="px-6 py-4 text-right text-sm text-slate-300 font-bold">{{ training.repetitions }}</td>
                                <td class="px-6 py-4 text-right text-sm">
                                    <span class="font-black text-primary">{{ training.weight|round(1) }} kg</span>
                                </td>
                                <td class="px-6 py-4 text-right text-sm">
                                    <span class="text-slate-400 font-bold">{{ (training.completedSeries * training.repetitions * training.weight)|round(0) }} kg</span>
                                </td>
                                <td class="px-6 py-4 text-right text-sm">
                                    <span class="text-purple-400 font-bold">
                                        {% if training.oneRmEstimated %}{{ training.oneRmEstimated|round(1) }} kg{% else %}—{% endif %}
                                    </span>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>{# fin grid #}

        {% endif %}
    </div>
</div>
{% endblock %}
