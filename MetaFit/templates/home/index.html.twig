{% extends 'base.html.twig' %}

{% block title %}Dashboard MetaFit AI{% endblock %}

{% block body %}
    <div class="bg-background-dark text-white min-h-screen">
        <div class="max-w-full mx-auto px-4 sm:px-6 pt-6 md:pt-8 pb-12 md:pb-16">

            {# HEADER CON BIENVENIDA Y BOTÓN #}
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-12">
                <div class="flex-1">
                    <h1 class="text-4xl sm:text-5xl md:text-6xl font-black italic uppercase tracking-tighter text-white">
                        ¡Hola, <span class="text-primary">{{ user.name|split(' ')[0] }}</span>!
                    </h1>
                    <p class="text-slate-400 text-sm md:text-base mt-3">
                        Aquí tienes tu información personal y la rutina que hemos preparado para ti.
                    </p>
                </div>
            </div>

            {# STATS PERSONALES #}
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
                <div class="bg-[#0d1117] border border-slate-800 p-6 rounded-2xl text-center flex flex-col justify-center">
                    <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest mb-2">Peso</p>
                    <p class="text-4xl font-black italic text-white">{{ user.actualWeight|default('--') }}<span class="text-primary text-sm ml-1">KG</span></p>
                </div>
                <div class="bg-[#0d1117] border border-slate-800 p-6 rounded-2xl text-center flex flex-col justify-center">
                    <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest mb-2">Altura</p>
                    <p class="text-4xl font-black italic text-white">{{ user.height|default('--') }}<span class="text-primary text-sm ml-1">CM</span></p>
                </div>
                <div class="bg-[#0d1117] border border-slate-800 p-6 rounded-2xl text-center flex flex-col justify-center">
                    <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest mb-2">Edad</p>
                    <p class="text-4xl font-black italic text-white">{{ user.age|default('--') }}<span class="text-primary text-sm ml-1">AÑOS</span></p>
                </div>
                <div class="bg-primary/10 border border-primary/30 p-6 rounded-2xl text-center flex flex-col justify-center">
                    <p class="text-primary text-[10px] font-bold uppercase tracking-widest mb-2">Tu IMC</p>
                    <p class="text-4xl font-black italic text-primary">{{ imc > 0 ? imc|number_format(1) : '--' }}</p>
                </div>
            </div>

            {# RUTINA ORGANIZADA POR DÍAS #}
            <div class="mb-12">
                <h2 class="text-3xl font-black italic uppercase tracking-tighter mb-8">Tu Rutina <span class="text-primary">Asignada</span></h2>
                
                {% if rutinaPorDias is empty %}
                    <div class="col-span-full py-20 text-center border-2 border-dashed border-slate-800 rounded-3xl">
                        <p class="text-slate-500 italic">No tienes ninguna rutina generada en este momento.</p>
                    </div>
                {% else %}
                    <div class="space-y-12">
                        {% for dia, ejercicios in rutinaPorDias %}
                            <div class="bg-[#0d1117]/50 p-6 md:p-8 rounded-3xl border border-slate-800/50">
                                <h3 class="text-2xl font-black italic text-white mb-6 flex items-center gap-3">
                                    <span class="bg-primary text-white text-sm px-4 py-1 rounded-full uppercase tracking-widest">{{ dia }}</span>
                                </h3>
                                
                                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                                    {% for ejercicio in ejercicios %}
                                        <div class="group bg-[#0d1117] border border-slate-800 rounded-2xl overflow-hidden hover:border-primary/50 transition-all">
                                            <div class="relative h-40 overflow-hidden">
                                                <img src="{{ ejercicio.getUrlImage()|default('https://images.unsplash.com/photo-1534438327276-14e5300c3a48') }}" class="w-full h-full object-cover">
                                                <div class="absolute top-3 left-3">
                                                    <span class="bg-black/80 text-white text-[9px] font-black px-2 py-1 rounded uppercase tracking-widest">
                                                        {{ ejercicio.getMuscularGroup() }}
                                                    </span>
                                                </div>
                                            </div>
                                            <div class="p-5">
                                                <h4 class="text-lg font-black italic uppercase text-white mb-2 line-clamp-1">{{ ejercicio.getName() }}</h4>
                                                <p class="text-slate-500 text-xs line-clamp-2 mb-4">{{ ejercicio.getDescription() }}</p>
                                                <div class="pt-3 border-t border-slate-800 flex justify-between items-center text-[9px] font-black uppercase tracking-widest">
                                                    <span class="text-slate-400">Esfuerzo</span>
                                                    <span class="text-primary">{{ ejercicio.getDifficulty() }}</span>
                                                </div>
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
