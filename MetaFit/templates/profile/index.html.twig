{% extends 'base.html.twig' %}

{% block title %}Mi Perfil - MetaFit AI{% endblock %}

{% block body %}
    <div class="bg-background-dark text-white">
        <div class="max-w-full mx-auto px-4 sm:px-6 py-6 md:py-8">

            {# HEADER #}
            <div class="mb-6 md:mb-8">
                <div class="flex items-center gap-4 mb-4">
                    <div class="h-1 w-12 bg-primary"></div>
                    <span class="text-primary font-bold tracking-[0.3em] uppercase text-sm">Configuración</span>
                </div>
                <h1 class="text-6xl font-black italic uppercase tracking-tighter mb-2">
                    Mi Perfil
                </h1>
                <p class="text-gray-400">{{ user.getEmail() }}</p>
            </div>

            {# GRID DE OPCIONES #}
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">

                {# INFORMACIÓN PERSONAL #}
                <a href="{{ path('profile_edit_personal') }}" class="group bg-[#0d1117] border border-slate-800 rounded-2xl p-6 hover:border-primary transition-all">
                    <div class="flex items-start gap-4">
                        <span class="material-symbols-outlined text-4xl text-primary group-hover:scale-110 transition-transform">person</span>
                        <div>
                            <h3 class="text-xl font-black uppercase">Información Personal</h3>
                            <p class="text-slate-400 text-sm mt-1">Nombre, edad, peso, objetivo</p>
                        </div>
                    </div>
                </a>

                {# PREFERENCIAS #}
                <a href="{{ path('profile_preferences') }}" class="group bg-[#0d1117] border border-slate-800 rounded-2xl p-6 hover:border-primary transition-all">
                    <div class="flex items-start gap-4">
                        <span class="material-symbols-outlined text-4xl text-primary group-hover:scale-110 transition-transform">tune</span>
                        <div>
                            <h3 class="text-xl font-black uppercase">Preferencias</h3>
                            <p class="text-slate-400 text-sm mt-1">Hora de entrenamiento, intensidad, notificaciones</p>
                        </div>
                    </div>
                </a>

                {# CONTRASEÑA #}
                <a href="{{ path('profile_change_password') }}" class="group bg-[#0d1117] border border-slate-800 rounded-2xl p-6 hover:border-primary transition-all">
                    <div class="flex items-start gap-4">
                        <span class="material-symbols-outlined text-4xl text-primary group-hover:scale-110 transition-transform">lock</span>
                        <div>
                            <h3 class="text-xl font-black uppercase">Contraseña</h3>
                            <p class="text-slate-400 text-sm mt-1">Cambiar contraseña de cuenta</p>
                        </div>
                    </div>
                </a>

            </div>

            {# TARJETAS DE RESUMEN #}
            <div class="grid md:grid-cols-3 gap-6">

                {# INFORMACIÓN DE CUENTA #}
                <div class="bg-[#0d1117] border border-slate-800 rounded-2xl p-6">
                    <h3 class="text-lg font-black uppercase mb-4">Información de Cuenta</h3>
                    <div class="space-y-3">
                        <div>
                            <p class="text-slate-400 text-sm">Email</p>
                            <p class="font-bold">{{ user.getEmail() }}</p>
                        </div>
                        <div>
                            <p class="text-slate-400 text-sm">Nivel</p>
                            <p class="font-bold text-primary">{{ user.getLevel() }}</p>
                        </div>
                        <div>
                            <p class="text-slate-400 text-sm">XP Acumulado</p>
                            <p class="font-bold">{{ user.getPointsXp() }}</p>
                        </div>
                        <div>
                            <p class="text-slate-400 text-sm">Cuenta creada</p>
                            <p class="font-bold">{{ user.getCreatedAt()|date('d/m/Y') }}</p>
                        </div>
                    </div>
                </div>

                {# DATOS PERSONALES #}
                <div class="bg-[#0d1117] border border-slate-800 rounded-2xl p-6">
                    <h3 class="text-lg font-black uppercase mb-4">Datos Personales</h3>
                    <div class="space-y-3">
                        <div>
                            <p class="text-slate-400 text-sm">Nombre</p>
                            <p class="font-bold">{{ user.getName() }} {{ user.getLastname() }}</p>
                        </div>
                        <div>
                            <p class="text-slate-400 text-sm">Edad</p>
                            <p class="font-bold">{{ user.getAge() ?? '—' }} años</p>
                        </div>
                        <div>
                            <p class="text-slate-400 text-sm">Peso actual</p>
                            <p class="font-bold">{{ user.getActualWeight() ?? '—' }} kg</p>
                        </div>
                        <div>
                            <p class="text-slate-400 text-sm">Objetivo</p>
                            <p class="font-bold">{{ user.getPurpose() ?? '—' }}</p>
                        </div>
                    </div>
                </div>

                {# PREFERENCIAS RÁPIDAS #}
                <div class="bg-[#0d1117] border border-slate-800 rounded-2xl p-6">
                    <h3 class="text-lg font-black uppercase mb-4">Preferencias</h3>
                    <div class="space-y-3">
                        {% if preferences %}
                            <div class="flex justify-between">
                                <span class="text-slate-400">Notificaciones</span>
                                <span class="{% if preferences.isNotificationsEnabled() %}text-emerald-400{% else %}text-slate-500{% endif %} font-bold">
                                    {% if preferences.isNotificationsEnabled() %}✓ Activadas{% else %}Desactivadas{% endif %}
                                </span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-slate-400">Perfil público</span>
                                <span class="{% if preferences.isProfilePublic() %}text-emerald-400{% else %}text-slate-500{% endif %} font-bold">
                                    {% if preferences.isProfilePublic() %}✓ Sí{% else %}Privado{% endif %}
                                </span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-slate-400">Unidad de medida</span>
                                <span class="font-bold">{{ preferences.getMeasurementUnit() }}</span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-slate-400">Intensidad</span>
                                <span class="font-bold capitalize">{{ preferences.getTrainingIntensity() ?? 'No configurada' }}</span>
                            </div>
                        {% else %}
                            <p class="text-slate-400 italic">No hay preferencias configuradas</p>
                        {% endif %}
                    </div>
                </div>

            </div>
        </div>
    </div>
{% endblock %}
