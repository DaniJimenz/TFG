{% extends 'base.html.twig' %}

{% block title %}Gestión de Ejercicios - Admin{% endblock %}

{% block body %}
<div class="max-w-full mx-auto px-4 sm:px-6 pt-6 md:pt-8">
    {# HEADER #}
    <div class="mb-12">
        <div class="flex items-center justify-between">
            <div>
                <div class="flex items-center gap-4 mb-4">
                    <div class="h-1 w-12 bg-red-500"></div>
                    <span class="text-red-500 font-bold tracking-[0.3em] uppercase text-sm">Administración</span>
                </div>
                <h1 class="text-5xl font-black italic uppercase tracking-tighter mb-2">
                    Ejercicios <span class="text-red-500">Base</span>
                </h1>
                <p class="text-gray-400 text-lg font-light">Crea, edita y elimina ejercicios de la plataforma</p>
            </div>
            <a href="{{ path('app_library_new') }}" class="bg-red-500 hover:bg-red-600 text-white px-6 py-3 rounded-xl transition-all font-bold text-sm uppercase flex items-center gap-2 h-fit">
                <span class="material-symbols-outlined">add</span>
                Nuevo Ejercicio
            </a>
        </div>
    </div>

    {# ESTADÍSTICAS #}
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-12">
        <div class="bg-[#0d1117] border border-slate-800 p-6 rounded-2xl">
            <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest mb-2">Total de Ejercicios</p>
            <p class="text-3xl font-black italic text-primary">{{ exercises|length }}</p>
        </div>
        <div class="bg-[#0d1117] border border-slate-800 p-6 rounded-2xl">
            <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest mb-2">Con Video</p>
            <p class="text-3xl font-black italic text-accent-purple">
                {% set with_video = exercises|filter(e => e.urlVideo)|length %}
                {{ with_video }}
            </p>
        </div>
        <div class="bg-[#0d1117] border border-slate-800 p-6 rounded-2xl">
            <p class="text-slate-500 text-[10px] font-bold uppercase tracking-widest mb-2">Con Imagen</p>
            <p class="text-3xl font-black italic text-green-500">
                {% set with_image = exercises|filter(e => e.urlImage)|length %}
                {{ with_image }}
            </p>
        </div>
    </div>

    {# TABLA DE EJERCICIOS #}
    <div class="bg-[#0d1117] border border-slate-800 rounded-2xl overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-slate-900/50 border-b border-slate-800">
                    <tr>
                        <th class="px-6 py-4 text-left text-sm font-bold uppercase tracking-widest text-slate-300">Ejercicio</th>
                        <th class="px-6 py-4 text-left text-sm font-bold uppercase tracking-widest text-slate-300">Grupo Muscular</th>
                        <th class="px-6 py-4 text-left text-sm font-bold uppercase tracking-widest text-slate-300">Dificultad</th>
                        <th class="px-6 py-4 text-left text-sm font-bold uppercase tracking-widest text-slate-300">Recurso</th>
                        <th class="px-6 py-4 text-left text-sm font-bold uppercase tracking-widest text-slate-300">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {% for exercise in exercises %}
                    <tr class="border-b border-slate-800 hover:bg-slate-900/50 transition-all">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                {% if exercise.urlImage %}
                                    <div class="w-10 h-10 rounded-lg overflow-hidden border border-slate-700 flex-shrink-0">
                                        <img src="{{ exercise.urlImage }}" alt="{{ exercise.name }}" class="w-full h-full object-cover">
                                    </div>
                                {% else %}
                                    <div class="w-10 h-10 rounded-lg bg-slate-800 flex items-center justify-center flex-shrink-0 border border-slate-700">
                                        <span class="material-symbols-outlined text-slate-600 text-lg">image_not_supported</span>
                                    </div>
                                {% endif %}
                                <span class="font-bold text-white">{{ exercise.name }}</span>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center gap-1 bg-primary/10 text-primary px-3 py-1 rounded-full text-xs font-bold uppercase border border-primary/20">
                                {{ exercise.muscularGroup }}
                            </span>
                        </td>
                        <td class="px-6 py-4">
                            <span class="text-xs font-bold">
                                {% if exercise.difficulty == 'Alta' %}
                                    <span class="text-red-500">{{ exercise.difficulty }}</span>
                                {% elseif exercise.difficulty == 'Media' %}
                                    <span class="text-yellow-500">{{ exercise.difficulty }}</span>
                                {% else %}
                                    <span class="text-green-500">{{ exercise.difficulty }}</span>
                                {% endif %}
                            </span>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-2">
                                {% if exercise.urlImage %}
                                    <span class="inline-flex items-center gap-1 text-green-400 text-xs font-bold">
                                        <span class="material-symbols-outlined text-sm">image</span>
                                    </span>
                                {% else %}
                                    <span class="inline-flex items-center gap-1 text-slate-600 text-xs font-bold">
                                        <span class="material-symbols-outlined text-sm">image</span>
                                    </span>
                                {% endif %}
                                {% if exercise.urlVideo %}
                                    <span class="inline-flex items-center gap-1 text-accent-purple text-xs font-bold">
                                        <span class="material-symbols-outlined text-sm">videocam</span>
                                    </span>
                                {% else %}
                                    <span class="inline-flex items-center gap-1 text-slate-600 text-xs font-bold">
                                        <span class="material-symbols-outlined text-sm">videocam</span>
                                    </span>
                                {% endif %}
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex gap-2">
                                <a href="{{ path('admin_exercises_quick_edit', {'id': exercise.id}) }}" class="p-2 bg-blue-900/20 text-blue-400 hover:bg-blue-900/40 rounded-lg transition-all" title="Editar">
                                    <span class="material-symbols-outlined">edit</span>
                                </a>
                                <a href="{{ path('app_library_edit', {'id': exercise.id}) }}" class="p-2 bg-slate-800 text-slate-300 hover:bg-slate-700 rounded-lg transition-all" title="Ver en biblioteca">
                                    <span class="material-symbols-outlined">open_in_new</span>
                                </a>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="5" class="px-6 py-12 text-center">
                            <div class="flex flex-col items-center justify-center text-slate-500">
                                <span class="material-symbols-outlined text-5xl mb-2">inventory_2</span>
                                <p>No hay ejercicios en la base de datos</p>
                                <a href="{{ path('app_library_new') }}" class="mt-4 bg-primary hover:bg-primary/90 text-white px-6 py-2 rounded-lg text-sm font-bold uppercase inline-flex items-center gap-2">
                                    <span class="material-symbols-outlined">add</span>
                                    Crear Primer Ejercicio
                                </a>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

</div>
{% endblock %}
