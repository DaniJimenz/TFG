{% extends 'base.html.twig' %}

{% block title %}Cambiar Contraseña - MetaFit AI{% endblock %}

{% block body %}
    <div class="bg-background-dark text-white">
        <div class="max-w-2xl mx-auto pt-14 md:pt-16">

            <a href="{{ path('profile_index') }}" class="inline-flex items-center gap-2 text-slate-400 hover:text-white mb-8 transition-all">
                <span class="material-symbols-outlined text-xl">arrow_back</span>
                Volver al Perfil
            </a>

            <div class="mb-12">
                <div class="flex items-center gap-4 mb-4">
                    <div class="h-1 w-12 bg-primary"></div>
                    <span class="text-primary font-bold tracking-[0.3em] uppercase text-sm">Seguridad</span>
                </div>
                <h1 class="text-5xl font-black italic uppercase tracking-tighter">
                    Cambiar Contraseña
                </h1>
            </div>

            {# ADVERTENCIA #}
            <div class="bg-gradient-to-r from-blue-500/10 to-transparent border border-blue-500/30 rounded-2xl p-6 mb-8">
                <div class="flex gap-3">
                    <span class="material-symbols-outlined text-2xl text-blue-400">lock_outline</span>
                    <div>
                        <p class="font-bold">Seguridad de Contraseña</p>
                        <p class="text-sm text-slate-400 mt-1">Para proteger tu cuenta, elige una contraseña segura y única. Mínimo 8 caracteres con combinación de letras, números y símbolos.</p>
                    </div>
                </div>
            </div>

            <form method="POST" class="bg-[#0d1117] border border-slate-800 rounded-2xl p-8 space-y-6">

                {# CONTRASEÑA ACTUAL #}
                <div>
                    <label class="block text-sm font-bold uppercase tracking-widest text-slate-300 mb-2">Contraseña Actual</label>
                    <input type="password" name="current_password" required class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-all" placeholder="••••••••">
                </div>

                {# NUEVA CONTRASEÑA #}
                <div>
                    <label class="block text-sm font-bold uppercase tracking-widest text-slate-300 mb-2">Nueva Contraseña</label>
                    <input type="password" name="new_password" required minlength="8" class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-all" placeholder="••••••••">
                    <p class="text-xs text-slate-400 mt-2">Mínimo 8 caracteres</p>
                </div>

                {# CONFIRMAR CONTRASEÑA #}
                <div>
                    <label class="block text-sm font-bold uppercase tracking-widest text-slate-300 mb-2">Confirmar Nueva Contraseña</label>
                    <input type="password" name="confirm_password" required minlength="8" class="w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-all" placeholder="••••••••">
                </div>

                {# REQUISITOS #}
                <div class="bg-slate-900/50 border border-slate-700 rounded-lg p-4">
                    <p class="text-sm font-bold uppercase tracking-widest text-slate-300 mb-3">Requisitos de Contraseña:</p>
                    <ul class="text-sm text-slate-400 space-y-2">
                        <li>✓ Mínimo 8 caracteres</li>
                        <li>✓ Incluir mayúsculas (A-Z)</li>
                        <li>✓ Incluir minúsculas (a-z)</li>
                        <li>✓ Incluir números (0-9)</li>
                        <li>✓ Incluir símbolos (!@#$%^&*)</li>
                    </ul>
                </div>

                {# BOTONES #}
                <div class="flex gap-4 pt-6">
                    <a href="{{ path('profile_index') }}" class="flex-1 bg-slate-800 hover:bg-slate-700 text-white px-6 py-3 rounded-xl transition-all font-bold uppercase text-center">
                        Cancelar
                    </a>
                    <button type="submit" class="flex-1 bg-primary hover:bg-primary/80 text-white px-6 py-3 rounded-xl transition-all font-bold uppercase">
                        ✓ Cambiar Contraseña
                    </button>
                </div>

            </form>
        </div>
    </div>
{% endblock %}
