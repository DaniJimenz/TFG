{% extends 'base.html.twig' %}

{% block title %}Crear Ejercicio - MetaFit AI{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-4 sm:px-6 pt-6 md:pt-8 pb-8">

    {# HEADER #}
    <div class="mb-8">
        <div class="flex items-center gap-4 mb-4">
            <div class="h-1 w-12 bg-red-500"></div>
            <span class="text-red-500 font-bold tracking-[0.3em] uppercase text-sm">Administración</span>
        </div>
        <div class="flex items-center gap-4">
            <a href="{{ path('admin_exercises_index') }}" class="inline-flex items-center gap-1 text-slate-400 hover:text-white transition-colors font-bold">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
            <h1 class="text-5xl font-black italic uppercase tracking-tighter">
                Nuevo <span class="text-red-500">Ejercicio</span>
            </h1>
        </div>
    </div>

    <div class="bg-[#0d1117] border border-slate-800 rounded-2xl p-6">

        {{ form_start(form, {'attr': {'class': 'space-y-5', 'novalidate': 'novalidate'}}) }}

            {# NOMBRE #}
            <div>
                {{ form_label(form.name, 'Nombre del Ejercicio', {'label_attr': {'class': 'block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1'}}) }}
                {{ form_widget(form.name, {'attr': {'class': 'w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2.5 text-white focus:border-red-500 focus:outline-none transition text-sm'}}) }}
                {{ form_errors(form.name) }}
            </div>

            {# GRUPO MUSCULAR + DIFICULTAD #}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    {{ form_label(form.muscular_group, 'Grupo Muscular', {'label_attr': {'class': 'block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1'}}) }}
                    {{ form_widget(form.muscular_group, {'attr': {'class': 'w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2.5 text-white focus:border-red-500 focus:outline-none transition text-sm'}}) }}
                </div>
                <div>
                    {{ form_label(form.difficulty, 'Dificultad', {'label_attr': {'class': 'block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1'}}) }}
                    {{ form_widget(form.difficulty, {'attr': {'class': 'w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2.5 text-white focus:border-red-500 focus:outline-none transition text-sm'}}) }}
                </div>
            </div>

            {# DESCRIPCIÓN + TÉCNICA #}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    {{ form_label(form.description, 'Descripción', {'label_attr': {'class': 'block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1'}}) }}
                    {{ form_widget(form.description, {'attr': {'class': 'w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2.5 text-white focus:border-red-500 focus:outline-none transition text-sm resize-none', 'rows': '3'}}) }}
                </div>
                <div>
                    {{ form_label(form.technique, 'Técnica de Ejecución', {'label_attr': {'class': 'block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1'}}) }}
                    {{ form_widget(form.technique, {'attr': {'class': 'w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2.5 text-white focus:border-red-500 focus:outline-none transition text-sm resize-none', 'rows': '3'}}) }}
                </div>
            </div>

            {# IMAGEN + VIDEO #}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    {{ form_label(form.url_image, 'Imagen del Ejercicio', {'label_attr': {'class': 'block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1'}}) }}
                    {{ form_widget(form.url_image, {'attr': {'class': 'w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2.5 text-white focus:border-red-500 focus:outline-none transition text-sm', 'accept': 'image/*'}}) }}
                    <p class="text-xs text-slate-500 mt-1">Máx 5MB (JPEG, PNG, WebP o GIF)</p>
                    {{ form_errors(form.url_image) }}
                </div>
                <div>
                    {{ form_label(form.url_video, 'URL de Video', {'label_attr': {'class': 'block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1'}}) }}
                    {{ form_widget(form.url_video, {'attr': {'class': 'w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2.5 text-white focus:border-red-500 focus:outline-none transition text-sm', 'placeholder': 'https://youtube.com/watch?v=...'}}) }}
                </div>
            </div>

            {# MATERIAL + COMPUESTO #}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 items-end">
                <div>
                    {{ form_label(form.necessary_material, 'Material Necesario', {'label_attr': {'class': 'block text-xs font-bold uppercase tracking-widest text-slate-400 mb-1'}}) }}
                    {{ form_widget(form.necessary_material, {'attr': {'class': 'w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-2.5 text-white focus:border-red-500 focus:outline-none transition text-sm', 'placeholder': 'Ej: Barra, Mancuernas'}}) }}
                </div>
                <div class="flex items-center gap-3 pb-1">
                    {{ form_widget(form.compound, {'attr': {'class': 'w-5 h-5 rounded accent-red-500'}}) }}
                    <span class="text-xs font-bold uppercase tracking-widest text-slate-400">¿Ejercicio Compuesto?</span>
                </div>
            </div>

            {# BOTONES #}
            <div class="flex gap-3 pt-3 border-t border-slate-800">
                <button type="submit" class="flex-1 bg-red-500 hover:bg-red-600 text-white px-6 py-2.5 rounded-lg transition-all font-bold text-sm uppercase">
                    Crear Ejercicio
                </button>
                <a href="{{ path('admin_exercises_index') }}" class="flex-1 border border-slate-700 hover:bg-slate-800 text-slate-400 hover:text-white px-6 py-2.5 rounded-lg transition-all font-bold text-sm uppercase text-center">
                    Cancelar
                </a>
            </div>

        {{ form_end(form) }}
    </div>

</div>
{% endblock %}
