{% extends 'base.html.twig' %}

{% block title %}Entrenar - MetaFit AI{% endblock %}

{% block body %}
    <div class="bg-background-dark text-white">
        <div class="max-w-4xl mx-auto pt-14 md:pt-16">

            {# HEADER #}
            <a href="{{ path('routine_index') }}" class="inline-flex items-center gap-2 text-slate-400 hover:text-white mb-8 transition-all">
                <span class="material-symbols-outlined text-xl">arrow_back</span>
                Volver a Rutinas
            </a>

            <div class="mb-12">
                <div class="flex items-center gap-4 mb-4">
                    <div class="h-1 w-12 bg-primary"></div>
                    <span class="text-primary font-bold tracking-[0.3em] uppercase text-sm">Sesión de Entrenamiento</span>
                </div>
                <h1 class="text-6xl font-black italic uppercase tracking-tighter mb-2">
                    {{ routine.getName() }}
                </h1>
                <p class="text-gray-400 text-lg">{{ routine.getExercises()|length }} ejercicios</p>
            </div>

            {# EJERCICIOS #}
            <div class="space-y-6 mb-12" id="exerciseContainer">
                {% for exercise in routine.getExercises() %}
                    <div class="bg-[#0d1117] border border-slate-800 rounded-2xl overflow-hidden" data-exercise-id="{{ exercise.id }}">
                        {# ENCABEZADO #}
                        <div class="bg-gradient-to-r from-primary/20 to-transparent p-6 border-b border-slate-700">
                            <div class="flex items-start justify-between">
                                <div>
                                    <h3 class="text-2xl font-black italic uppercase text-white mb-2">{{ exercise.getName() }}</h3>
                                    <p class="text-slate-400">{{ exercise.getDescription()|truncate(100) }}</p>
                                </div>
                                <div class="text-right">
                                    <span class="inline-block bg-primary/30 text-primary text-xs font-black px-3 py-1 rounded-lg mb-2">
                                        {{ exercise.getMuscularGroup() }}
                                    </span>
                                    <p class="text-slate-500 text-xs">Dificultad: {{ exercise.getDifficulty() }}</p>
                                </div>
                            </div>
                        </div>

                        {# CONTROLES #}
                        <div class="p-6 space-y-4">
                            <div class="grid grid-cols-3 gap-4">
                                <div>
                                    <label class="block text-sm font-bold uppercase tracking-widest text-slate-300 mb-2">Series</label>
                                    <input type="number" min="1" value="3" class="exercise-series w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-all" data-exercise-id="{{ exercise.id }}">
                                </div>
                                <div>
                                    <label class="block text-sm font-bold uppercase tracking-widest text-slate-300 mb-2">Repeticiones</label>
                                    <input type="number" min="1" value="10" class="exercise-reps w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-all" data-exercise-id="{{ exercise.id }}">
                                </div>
                                <div>
                                    <label class="block text-sm font-bold uppercase tracking-widest text-slate-300 mb-2">Peso (kg)</label>
                                    <input type="number" step="0.5" min="0" value="20" class="exercise-weight w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-all" data-exercise-id="{{ exercise.id }}">
                                </div>
                            </div>

                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-sm font-bold uppercase tracking-widest text-slate-300 mb-2">Duración (min)</label>
                                    <input type="number" min="0" value="5" class="exercise-duration w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary transition-all" data-exercise-id="{{ exercise.id }}">
                                </div>
                                <div>
                                    <label class="block text-sm font-bold uppercase tracking-widest text-slate-300 mb-2">Notas</label>
                                    <input type="text" placeholder="Ej: Buen desempeño..." class="exercise-notes w-full bg-slate-900 border border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-primary transition-all" data-exercise-id="{{ exercise.id }}">
                                </div>
                            </div>

                            {# CÁLCULOS #}
                            <div class="bg-slate-900/50 border border-slate-700 rounded-lg p-4 space-y-2">
                                <div class="flex justify-between text-sm">
                                    <span class="text-slate-400">Volumen Total:</span>
                                    <span class="font-bold text-primary" class="volume-{{ exercise.id }}">0 kg</span>
                                </div>
                                <div class="flex justify-between text-sm">
                                    <span class="text-slate-400">1RM Estimado:</span>
                                    <span class="font-bold" class="oneRM-{{ exercise.id }}">-- kg</span>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            {# BOTONES #}
            <div class="flex gap-4 sticky bottom-8">
                <a href="{{ path('routine_index') }}" class="flex-1 bg-slate-800 hover:bg-slate-700 text-white px-6 py-3 rounded-xl transition-all font-bold uppercase text-center">
                    Cancelar
                </a>
                <button type="button" onclick="completeTraining({{ routine.id }})" class="flex-1 bg-primary hover:bg-primary/80 text-white px-6 py-3 rounded-xl transition-all font-bold uppercase">
                    ✓ Completar Entrenamiento
                </button>
            </div>
        </div>
    </div>

    <script>
        // Actualizar cálculos en tiempo real
        document.querySelectorAll('[class*="exercise-"]').forEach(input => {
            input.addEventListener('change', updateCalculations);
            input.addEventListener('input', updateCalculations);
        });

        function updateCalculations() {
            document.querySelectorAll('[data-exercise-id]').forEach(el => {
                const exerciseId = el.getAttribute('data-exercise-id');
                const container = document.querySelector(`[data-exercise-id="${exerciseId}"]`);
                
                const series = parseInt(container.querySelector('.exercise-series').value) || 0;
                const reps = parseInt(container.querySelector('.exercise-reps').value) || 0;
                const weight = parseFloat(container.querySelector('.exercise-weight').value) || 0;

                // Volumen = Series x Reps x Weight
                const volume = series * reps * weight;
                document.querySelector(`.volume-${exerciseId}`).textContent = `${volume.toFixed(0)} kg`;

                // 1RM usando fórmula Brzycki
                if (reps > 0 && reps < 37 && weight > 0) {
                    const oneRM = weight * (36 / (37 - reps));
                    document.querySelector(`.oneRM-${exerciseId}`).textContent = `${oneRM.toFixed(1)} kg`;
                }
            });
        }

        function completeTraining(routineId) {
            const exercises = {};
            
            document.querySelectorAll('[data-exercise-id]').forEach(container => {
                const exerciseId = container.getAttribute('data-exercise-id');
                exercises[exerciseId] = {
                    completed_series: parseInt(container.querySelector('.exercise-series').value),
                    repetitions: parseInt(container.querySelector('.exercise-reps').value),
                    weight: parseFloat(container.querySelector('.exercise-weight').value),
                    duration_minutes: parseInt(container.querySelector('.exercise-duration').value),
                    notes: container.querySelector('.exercise-notes').value,
                    completed: true,
                };
            });

            fetch(`{{ path('routine_complete', {id: routine.id}) }}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ exercises })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success || data.message) {
                    window.location.href = "{{ path('routine_index') }}";
                }
            })
            .catch(err => console.error('Error:', err));
        }

        // Inicializar cálculos
        updateCalculations();
    </script>
{% endblock %}
