<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}MetaFit AI{% endblock %}</title>

    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">

    {% block stylesheets %}
        <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
        <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
        <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>

        <script>
            tailwind.config = {
                darkMode: "class",
                theme: {
                    extend: {
                        colors: {
                            "primary": "#0d59f2",
                            "accent-purple": "#8b5cf6",
                            "background-dark": "#0a0c12",
                        },
                        fontFamily: { "display": ["Space Grotesk", "sans-serif"] }
                    },
                },
            }
        </script>
        <style type="text/tailwindcss">
            @layer base {
                body { font-family: 'Space Grotesk', sans-serif; }
            }
            .bg-mesh {
                background-color: #0a0c12;
                background-image:
                    radial-gradient(at 0% 0%, rgba(13, 89, 242, 0.12) 0px, transparent 40%),
                    radial-gradient(at 100% 100%, rgba(139, 92, 246, 0.08) 0px, transparent 40%);
            }
        </style>
    {% endblock %}

    {% block javascripts %}
        {{ importmap('app') }}
    {% endblock %}
</head>
<body class="bg-background-dark text-slate-200 font-display min-h-screen bg-mesh overflow-hidden">

{% set show_ui = app.user and app.request.attributes.get('_route') != 'app_onboarding' %}

<div class="flex h-screen w-screen overflow-hidden">

    {# --- SIDEBAR (Para todos los usuarios) --- #}
    {% if show_ui %}
        <aside class="w-64 bg-[#0d1117] border-r border-slate-800/50 flex flex-col shrink-0 z-50">
            <div class="p-6 flex flex-col h-full">
                {# Logo MetaFit AI - Clickeable al dashboard #}
                <a href="{{ path('app_home') }}" class="flex items-center gap-3 mb-10 px-2 hover:opacity-80 transition-opacity">
                    <h1 class="text-xl font-black italic uppercase text-white tracking-tighter">
                        META<span class="text-primary">FIT</span>
                    </h1>
                </a>

                {# Enlaces de navegación #}
                <nav class="space-y-2 flex-1">
                    <a href="{{ path('meal_index') }}" class="flex items-center gap-4 px-4 py-3 rounded-xl {% if 'meal_' in app.request.attributes.get('_route') %}bg-primary/10 text-primary border border-primary/20{% else %}text-slate-400 hover:bg-slate-800/50 hover:text-white{% endif %} transition-all font-bold text-sm tracking-widest uppercase">
                        <span class="material-symbols-outlined">nutrition</span>
                        Nutrición
                    </a>
                    <a href="{{ path('training_index') }}" class="flex items-center gap-4 px-4 py-3 rounded-xl {% if 'training_' in app.request.attributes.get('_route') %}bg-primary/10 text-primary border border-primary/20{% else %}text-slate-400 hover:bg-slate-800/50 hover:text-white{% endif %} transition-all font-bold text-sm tracking-widest uppercase">
                        <span class="material-symbols-outlined">fitness_center</span>
                        Entrenamientos
                    </a>
                    <a href="{{ path('app_library_index') }}" class="flex items-center gap-4 px-4 py-3 rounded-xl text-slate-400 hover:bg-slate-800/50 hover:text-white transition-all font-bold text-sm tracking-widest uppercase">
                        <span class="material-symbols-outlined">library_books</span>
                        Biblioteca
                    </a>
                    <a href="{{ path('achievement_index') }}" class="flex items-center gap-4 px-4 py-3 rounded-xl {% if 'achievement_' in app.request.attributes.get('_route') %}bg-primary/10 text-primary border border-primary/20{% else %}text-slate-400 hover:bg-slate-800/50 hover:text-white{% endif %} transition-all font-bold text-sm tracking-widest uppercase">
                        <span class="material-symbols-outlined">trophy</span>
                        Logros
                    </a>
                    {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('admin_exercises_index') }}" class="flex items-center gap-4 px-4 py-3 rounded-xl text-slate-400 hover:bg-slate-800/50 hover:text-white transition-all font-bold text-sm tracking-widest uppercase">
                        <span class="material-symbols-outlined">settings</span>
                        Administrar Ejercicios
                    </a>
                    {% endif %}
                    <a href="#" class="flex items-center gap-4 px-4 py-3 rounded-xl text-slate-400 hover:bg-slate-800/50 hover:text-white transition-all font-bold text-sm tracking-widest uppercase">
                        <span class="material-symbols-outlined">groups</span>
                        Comunidad
                    </a>
                </nav>

                {# Usuario Inferior #}
                <div class="pt-6 border-t border-slate-800/50">
                    <div class="flex items-center gap-3 p-2">
                        <div class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center font-bold text-primary">
                            {{ app.user.name|first|upper }}
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-bold truncate leading-none">{{ app.user.name }}</p>
                            <p class="text-[10px] text-primary font-bold uppercase mt-1">User</p>
                        </div>
                    </div>
                </div>
            </div>
        </aside>
    {% endif %}

    {# --- CONTENIDO DERECHA (Top Nav + Bloque Body) --- #}
    <div class="flex-1 flex flex-col min-w-0">

        {# Navbar Superior (Estadísticas y Logout) #}
        {% if show_ui %}
            <header class="bg-[#0d1117]/50 backdrop-blur-md border-b border-slate-800/50 flex items-center px-2 sm:px-4 md:px-6 py-2 shrink-0 sticky top-0 z-40">
                <div class="flex items-center justify-between w-full max-w-7xl mx-auto gap-2 sm:gap-4">
                    {# Espacio vacío a la izquierda #}
                    <div class="flex-1"></div>

                    <div class="flex items-center gap-1 sm:gap-2 flex-shrink-0">
                        {# Racha #}
                        <div class="flex items-center gap-1 bg-orange-500/10 text-orange-500 px-2 py-1 rounded-full border border-orange-500/20 text-[8px] sm:text-[10px] font-bold uppercase">
                            <span class="material-symbols-outlined text-xs sm:text-sm">local_fire_department</span>
                            <span class="hidden sm:inline">0 DÍAS</span>
                            <span class="sm:hidden">0D</span>
                        </div>

                        {# Barra de Nivel (oculta en móviles) #}
                        <div class="hidden lg:flex items-center gap-2">
                            <div class="text-right leading-none">
                                <p class="text-[8px] font-bold text-slate-500 uppercase tracking-widest">Nivel 0</p>
                                <p class="text-[10px] font-black text-primary italic uppercase">NOVATO</p>
                            </div>
                            <div class="w-20 h-1.5 bg-slate-800 rounded-full overflow-hidden">
                                <div class="bg-primary h-full w-0 shadow-[0_0_8px_rgba(13,89,242,0.6)]"></div>
                            </div>
                            <span class="text-[8px] font-bold text-slate-400">0/1000 XP</span>
                        </div>

                        {# Perfil y Logout #}
                        <a href="{{ path('profile_index') }}" class="p-1.5 sm:p-2 rounded-lg bg-slate-800/40 border border-slate-700/50 text-slate-400 hover:text-primary transition-all flex items-center" title="Mi Perfil">
                            <span class="material-symbols-outlined text-sm sm:text-lg">person</span>
                        </a>
                        <a href="{{ path('app_logout') }}" class="p-1.5 sm:p-2 rounded-lg bg-slate-800/40 border border-slate-700/50 text-slate-400 hover:text-red-400 transition-all flex items-center" title="Cerrar Sesión">
                            <span class="material-symbols-outlined text-sm sm:text-lg">logout</span>
                        </a>
                    </div>
                </div>
            </header>
        {% endif %}

        {# Bloque Body Principal #}
        <main class="flex-1 overflow-y-auto">
            {% block body %}{% endblock %}
        </main>
    </div>
</div>

</body>
</html>
