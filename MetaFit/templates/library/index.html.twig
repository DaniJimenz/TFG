{% extends 'base.html.twig' %}

{% block title %}Biblioteca de Ejercicios - MetaFit AI{% endblock %}

{% block body %}
    <div class="max-w-7xl mx-auto">
        {# Título y subtítulo con estilo MetaFit #}
        <div class="mb-10 flex items-center justify-between">
            <div>
                <h1 class="text-4xl font-black italic uppercase text-white tracking-tighter">
                    Biblioteca de <span class="text-primary">Ejercicios</span>
                </h1>
                <p class="text-slate-500 mt-2 font-medium">Domina cada movimiento con guías de técnica impulsadas por IA.</p>
            </div>
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_library_new') }}" class="bg-primary hover:bg-primary/90 text-white px-6 py-3 rounded-xl transition-all font-bold text-sm uppercase flex items-center gap-2">
                    <span class="material-symbols-outlined">add</span>
                    Nuevo Ejercicio
                </a>
            {% endif %}
        </div>

        {# Buscador estilizado #}
        <div class="relative mb-8">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-primary">search</span>
            <input type="text" id="exerciseSearch"
                   placeholder="Buscar ejercicios (ej. Press de Banca, Sentadilla)..."
                   class="w-full bg-[#0d1117] border border-slate-800/50 rounded-2xl py-4 pl-12 pr-4 text-white placeholder:text-slate-600 focus:outline-none focus:border-primary/50 transition-all shadow-inner">
        </div>

        {# Filtros de Categoría #}
        <div class="flex flex-wrap gap-3 mb-12">
            {% set categories = ['Todos', 'Pecho', 'Espalda', 'Piernas', 'Hombros', 'Brazos', 'Core', 'Antebrazos', 'Glúteos'] %}
            {% for cat in categories %}
                <button class="category-btn px-6 py-2 rounded-xl font-bold text-xs uppercase tracking-widest transition-all
                {{ loop.first ? 'bg-primary text-white active-cat shadow-[0_0_20px_rgba(13,89,242,0.3)]' : 'bg-slate-900/40 text-slate-500 border border-slate-800/50 hover:border-primary/30 hover:text-white' }}"
                        data-category="{{ cat }}">
                    {{ cat }}
                </button>
            {% endfor %}
        </div>

        {# Grid de Tarjetas Dinámicas #}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="exerciseGrid">
            {% for exercise in exercises %}
                <div class="exercise-card cursor-pointer bg-[#0d1117]/40 border border-slate-800/50 rounded-3xl overflow-hidden group hover:border-primary/40 transition-all duration-500"
                     data-name="{{ exercise.name|lower }}"
                     data-group="{{ exercise.muscularGroup }}"
                     data-desc="{{ exercise.description|escape('html') }}"
                     data-tech="{{ exercise.technique|escape('html') }}"
                     data-video="{{ exercise.urlVideo|escape('html') }}">

                    <div class="relative aspect-video overflow-hidden">
                        <img src="{{ exercise.urlImage }}" alt="{{ exercise.name }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy">
                        <div class="absolute bottom-3 right-3 bg-black/70 backdrop-blur-md px-2 py-1 rounded-md text-[10px] font-bold text-white tracking-tighter">
                            {{ exercise.difficulty|default('MEDIA')|upper }}
                        </div>
                        {# Icono de play overlay al hacer hover #}
                        <div class="absolute inset-0 bg-primary/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                            <span class="material-symbols-outlined text-white text-5xl">play_circle</span>
                        </div>
                    </div>

                    <div class="p-6">
                        <div class="flex justify-between items-start mb-2">
                            <h3 class="text-xl font-bold text-white uppercase italic tracking-tighter">{{ exercise.name }}</h3>
                            <span class="px-2 py-0.5 bg-primary/10 text-primary text-[9px] font-black rounded uppercase border border-primary/20">
                                {{ exercise.muscularGroup }}
                            </span>
                        </div>
                        <p class="text-[10px] text-primary/80 font-bold uppercase tracking-widest mb-3">Técnica: {{ exercise.technique }}</p>
                        <p class="text-sm text-slate-500 leading-relaxed font-medium line-clamp-2">{{ exercise.description }}</p>
                        
                        {% if is_granted('ROLE_ADMIN') %}
                            <div class="flex gap-2 mt-4 pt-4 border-t border-slate-700/50">
                                <a href="{{ path('app_library_edit', {'id': exercise.id}) }}" class="flex-1 text-center bg-slate-800 hover:bg-slate-700 text-slate-300 hover:text-white px-3 py-2 rounded-lg transition-all font-bold text-xs uppercase">
                                    Editar
                                </a>
                                <form method="POST" action="{{ path('app_library_delete', {'id': exercise.id}) }}" style="flex: 1;" onsubmit="return confirm('¿Estás seguro?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_exercise_' ~ exercise.id) }}">
                                    <button type="submit" class="w-full border border-red-700/50 hover:bg-red-500/10 text-red-500 px-3 py-2 rounded-lg transition-all font-bold text-xs uppercase">
                                        Eliminar
                                    </button>
                                </form>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% else %}
                <div class="col-span-full text-center py-20">
                    <span class="material-symbols-outlined text-6xl text-slate-700 mb-4">fitness_center</span>
                    <p class="text-slate-500">No hay ejercicios en la base de datos.</p>
                </div>
            {% endfor %}
        </div>
    </div>

    {# Modal de Modo Enfoque #}
    <div id="exerciseModal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4 bg-black/90 backdrop-blur-sm transition-all">
        <div class="bg-[#0d1117] border border-slate-800 w-full max-w-4xl rounded-3xl overflow-hidden shadow-2xl relative">
            <button id="closeModal" class="absolute top-5 right-5 z-10 text-slate-400 hover:text-white bg-slate-800/50 p-2 rounded-full transition-all">
                <span class="material-symbols-outlined">close</span>
            </button>

            <div class="flex flex-col md:flex-row h-full max-h-[90vh]">
                <div class="md:w-3/5 bg-black flex items-center justify-center relative aspect-video md:aspect-auto">
                    <video id="modalVideo" controls class="w-full h-full object-cover">
                        <source src="" type="video/mp4">
                    </video>
                    <div id="videoPlaceholder" class="absolute inset-0 flex items-center justify-center bg-slate-900 text-slate-500 italic text-sm text-center p-8">
                        <div>
                            <span class="material-symbols-outlined text-4xl mb-2">videocam_off</span>
                            <p>Vídeo de técnica no disponible para este ejercicio</p>
                        </div>
                    </div>
                </div>

                <div class="md:w-2/5 p-8 overflow-y-auto bg-[#0d1117]">
                    <span id="modalGroup" class="text-primary text-[10px] font-black uppercase tracking-[0.2em] border border-primary/20 px-3 py-1 rounded-full bg-primary/5"></span>
                    <h2 id="modalName" class="text-3xl font-black italic uppercase text-white mt-4 mb-2 tracking-tighter leading-none"></h2>
                    <p id="modalTechnique" class="text-primary/80 font-bold text-xs uppercase mb-6"></p>

                    <div class="space-y-6">
                        <div>
                            <h4 class="text-white font-bold text-sm uppercase mb-2 tracking-widest">Instrucciones</h4>
                            <p id="modalDesc" class="text-slate-400 text-sm leading-relaxed font-medium"></p>
                        </div>
                        <div class="pt-6 border-t border-slate-800/50">
                            <button class="w-full py-4 bg-primary text-white font-black italic uppercase tracking-widest rounded-xl hover:shadow-[0_0_30px_rgba(13,89,242,0.4)] transition-all">
                                Añadir a mi rutina
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const searchInput = document.getElementById('exerciseSearch');
            const categoryBtns = document.querySelectorAll('.category-btn');
            const cards = document.querySelectorAll('.exercise-card');
            const modal = document.getElementById('exerciseModal');
            const closeModal = document.getElementById('closeModal');
            const videoElement = document.getElementById('modalVideo');
            const placeholder = document.getElementById('videoPlaceholder');

            // Establecer "Todos" como categoría inicial activa
            const firstBtn = document.querySelector('.category-btn');
            if (firstBtn) {
                firstBtn.classList.add('bg-primary', 'text-white', 'active-cat', 'shadow-[0_0_20px_rgba(13,89,242,0.3)]');
                firstBtn.classList.remove('bg-slate-900/40', 'text-slate-500');
            }

            // --- LÓGICA DE FILTRADO ---
            function filterExercises() {
                const searchTerm = searchInput.value.toLowerCase().trim();
                const activeBtn = document.querySelector('.active-cat');
                const activeCategory = activeBtn ? activeBtn.textContent.trim() : 'Todos';

                cards.forEach(card => {
                    const name = card.dataset.name.toLowerCase();
                    const group = card.dataset.group;

                    const matchesSearch = searchTerm === '' || name.includes(searchTerm);
                    const matchesCategory = activeCategory === 'Todos' || group === activeCategory;

                    card.style.display = (matchesSearch && matchesCategory) ? 'block' : 'none';
                });
            }

            searchInput.addEventListener('input', filterExercises);

            categoryBtns.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    categoryBtns.forEach(b => {
                        b.classList.remove('bg-primary', 'text-white', 'active-cat', 'shadow-[0_0_20px_rgba(13,89,242,0.3)]');
                        b.classList.add('bg-slate-900/40', 'text-slate-500');
                    });
                    btn.classList.add('bg-primary', 'text-white', 'active-cat', 'shadow-[0_0_20px_rgba(13,89,242,0.3)]');
                    btn.classList.remove('bg-slate-900/40', 'text-slate-500');
                    filterExercises();
                });
            });

            // --- LÓGICA DEL MODAL (MODO ENFOQUE) ---
            cards.forEach(card => {
                card.addEventListener('click', () => {
                    // Mapeo de datos desde los atributos data- de la tarjeta
                    document.getElementById('modalName').innerText = card.querySelector('h3').innerText;
                    document.getElementById('modalGroup').innerText = card.dataset.group;
                    document.getElementById('modalDesc').innerText = card.dataset.desc;
                    document.getElementById('modalTechnique').innerText = "Técnica: " + card.dataset.tech;

                    const videoUrl = card.dataset.video;

                    if (videoUrl && videoUrl !== "" && videoUrl !== "null") {
                        videoElement.src = videoUrl;
                        videoElement.classList.remove('hidden');
                        placeholder.classList.add('hidden');
                    } else {
                        videoElement.src = "";
                        videoElement.classList.add('hidden');
                        placeholder.classList.remove('hidden');
                    }

                    // Mostrar modal con animación sencilla
                    modal.classList.remove('hidden');
                    modal.classList.add('flex');
                    document.body.style.overflow = 'hidden';
                });
            });

            const hideModal = () => {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
                videoElement.pause();
                videoElement.src = "";
                document.body.style.overflow = 'auto';
            };

            closeModal.addEventListener('click', hideModal);

            // Cerrar al hacer clic fuera del contenido del modal
            modal.addEventListener('click', (e) => {
                if (e.target === modal) hideModal();
            });
        });
    </script>
{% endblock %}

